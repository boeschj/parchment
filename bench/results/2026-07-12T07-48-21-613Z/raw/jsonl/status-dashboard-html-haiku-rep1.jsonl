alue\">4m 12s</div>\n                <div class=\"kpi-trend\">↑ +45s from yesterday</div>\n            </div>\n            <div class=\"kpi-card danger\">\n                <div class=\"kpi-label\">Open Incidents</div>\n                <div class=\"kpi-value\">2</div>\n                <div class=\"kpi-trend\">High priority: 1</div>\n            </div>\n        </div>\n\n        <div class=\"charts-grid\">\n            <div class=\"chart-container\">\n                <div class=\"chart-title\">Build Durations (Last 7 Days)</div>\n                <svg viewBox=\"0 0 600 350\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <!-- Axes -->\n                    <line x1=\"60\" y1=\"280\" x2=\"580\" y2=\"280\" stroke=\"#404040\" stroke-width=\"2\"/>\n                    <line x1=\"60\" y1=\"280\" x2=\"60\" y2=\"40\" stroke=\"#404040\" stroke-width=\"2\"/>\n\n                    <!-- Grid lines -->\n                    <line x1=\"60\" y1=\"240\" x2=\"580\" y2=\"240\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"200\" x2=\"580\" y2=\"200\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"160\" x2=\"580\" y2=\"160\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"120\" x2=\"580\" y2=\"120\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"80\" x2=\"580\" y2=\"80\" stroke=\"#303030\" stroke-width=\"1\"/>\n\n                    <!-- Y-axis labels -->\n                    <text x=\"50\" y=\"285\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">0</text>\n                    <text x=\"50\" y=\"245\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">5</text>\n                    <text x=\"50\" y=\"205\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">10</text>\n                    <text x=\"50\" y=\"165\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">15</text>\n                    <text x=\"50\" y=\"125\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">20</text>\n\n                    <!-- Bars: 12, 8, 15, 9, 20, 7, 11 -->\n                    <!-- Mon: 12 -->\n                    <rect x=\"80\" y=\"168\" width=\"45\" height=\"112\" fill=\"#4ade80\" opacity=\"0.8\"/>\n                    <!-- Tue: 8 -->\n                    <rect x=\"140\" y=\"216\" width=\"45\" height=\"64\" fill=\"#4ade80\" opacity=\"0.8\"/>\n                    <!-- Wed: 15 -->\n                    <rect x=\"200\" y=\"120\" width=\"45\" height=\"160\" fill=\"#4ade80\" opacity=\"0.8\"/>\n                    <!-- Thu: 9 -->\n                    <rect x=\"260\" y=\"208\" width=\"45\" height=\"72\" fill=\"#4ade80\" opacity=\"0.8\"/>\n                    <!-- Fri: 20 -->\n                    <rect x=\"320\" y=\"120\" width=\"45\" height=\"160\" fill=\"#ff6b6b\" opacity=\"0.8\"/>\n                    <!-- Sat: 7 -->\n                    <rect x=\"380\" y=\"224\" width=\"45\" height=\"56\" fill=\"#4ade80\" opacity=\"0.8\"/>\n                    <!-- Sun: 11 -->\n                    <rect x=\"440\" y=\"176\" width=\"45\" height=\"104\" fill=\"#4ade80\" opacity=\"0.8\"/>\n\n                    <!-- X-axis labels -->\n                    <text x=\"102\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Mon</text>\n                    <text x=\"162\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Tue</text>\n                    <text x=\"222\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Wed</text>\n                    <text x=\"282\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Thu</text>\n                    <text x=\"342\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Fri</text>\n                    <text x=\"402\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Sat</text>\n                    <text x=\"462\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Sun</text>\n\n                    <!-- Value labels on bars -->\n                    <text x=\"102\" y=\"155\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">12</text>\n                    <text x=\"162\" y=\"205\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">8</text>\n                    <text x=\"222\" y=\"105\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">15</text>\n                    <text x=\"282\" y=\"195\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">9</text>\n                    <text x=\"342\" y=\"105\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">20</text>\n                    <text x=\"402\" y=\"215\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">7</text>\n                    <text x=\"462\" y=\"163\" text-anchor=\"middle\" font-size=\"12\" fill=\"#fff\" font-weight=\"bold\">11</text>\n\n                    <!-- Y-axis title -->\n                    <text x=\"20\" y=\"160\" text-anchor=\"middle\" font-size=\"12\" fill=\"#a0a0a0\" transform=\"rotate(-90 20 160)\">Minutes</text>\n                </svg>\n            </div>\n\n            <div class=\"chart-container\">\n                <div class=\"chart-title\">Daily Deploy Counts (Last 7 Days)</div>\n                <svg viewBox=\"0 0 600 350\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <!-- Axes -->\n                    <line x1=\"60\" y1=\"280\" x2=\"580\" y2=\"280\" stroke=\"#404040\" stroke-width=\"2\"/>\n                    <line x1=\"60\" y1=\"280\" x2=\"60\" y2=\"40\" stroke=\"#404040\" stroke-width=\"2\"/>\n\n                    <!-- Grid lines -->\n                    <line x1=\"60\" y1=\"240\" x2=\"580\" y2=\"240\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"200\" x2=\"580\" y2=\"200\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"160\" x2=\"580\" y2=\"160\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"120\" x2=\"580\" y2=\"120\" stroke=\"#303030\" stroke-width=\"1\"/>\n                    <line x1=\"60\" y1=\"80\" x2=\"580\" y2=\"80\" stroke=\"#303030\" stroke-width=\"1\"/>\n\n                    <!-- Y-axis labels -->\n                    <text x=\"50\" y=\"285\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">0</text>\n                    <text x=\"50\" y=\"245\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">2</text>\n                    <text x=\"50\" y=\"205\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">4</text>\n                    <text x=\"50\" y=\"165\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">6</text>\n                    <text x=\"50\" y=\"125\" text-anchor=\"end\" font-size=\"12\" fill=\"#808080\">8</text>\n\n                    <!-- Polyline for the line chart: 3, 5, 2, 6, 4, 7, 3 -->\n                    <!-- Points calculated: y = 280 - (value * 40) -->\n                    <!-- Mon (3): y=160, Tue (5): y=80, Wed (2): y=200, Thu (6): y=40, Fri (4): y=120, Sat (7): y=0, Sun (3): y=160 -->\n                    <polyline points=\"102,160 162,80 222,200 282,40 342,120 402,0 462,160\"\n                              fill=\"none\" stroke=\"#60a5fa\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n\n                    <!-- Data points -->\n                    <circle cx=\"102\" cy=\"160\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"162\" cy=\"80\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"222\" cy=\"200\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"282\" cy=\"40\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"342\" cy=\"120\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"402\" cy=\"0\" r=\"5\" fill=\"#60a5fa\"/>\n                    <circle cx=\"462\" cy=\"160\" r=\"5\" fill=\"#60a5fa\"/>\n\n                    <!-- Value labels -->\n                    <text x=\"102\" y=\"148\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">3</text>\n                    <text x=\"162\" y=\"68\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">5</text>\n                    <text x=\"222\" y=\"220\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">2</text>\n                    <text x=\"282\" y=\"25\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">6</text>\n                    <text x=\"342\" y=\"108\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">4</text>\n                    <text x=\"402\" y=\"30\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">7</text>\n                    <text x=\"462\" y=\"148\" text-anchor=\"middle\" font-size=\"12\" fill=\"#60a5fa\" font-weight=\"bold\">3</text>\n\n                    <!-- X-axis labels -->\n                    <text x=\"102\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Mon</text>\n                    <text x=\"162\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Tue</text>\n                    <text x=\"222\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Wed</text>\n                    <text x=\"282\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Thu</text>\n                    <text x=\"342\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Fri</text>\n                    <text x=\"402\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Sat</text>\n                    <text x=\"462\" y=\"300\" text-anchor=\"middle\" font-size=\"12\" fill=\"#808080\">Sun</text>\n\n                    <!-- Y-axis title -->\n                    <text x=\"20\" y=\"160\" text-anchor=\"middle\" font-size=\"12\" fill=\"#a0a0a0\" transform=\"rotate(-90 20 160)\">Deploys</text>\n                </svg>\n            </div>\n        </div>\n    </div>\n</body>\n</html>\n","structuredPatch":[],"originalFile":null,"userModified":false},"sourceToolAssistantUUID":"d33221d9-5dc8-4282-b3b3-d0808679c8e4","userType":"external","entrypoint":"sdk-cli","cwd":"/Users/boeschj/Documents/GitHub/parchment/bench/.runs/2026-07-12T07-48-21-613Z/status-dashboard/html/rep-1","sessionId":"6a5b5c5e-d0b1-4d2a-8421-ae448f16629f","version":"2.1.207","gitBranch":"main"}
