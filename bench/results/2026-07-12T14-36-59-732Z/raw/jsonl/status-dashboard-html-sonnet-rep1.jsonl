>\n\n    <div class=\"chart-card\">\n      <div class=\"chart-title\">Deploy Count (last 7 days)</div>\n      <div class=\"chart-sub\">Deploys per day, Mon&ndash;Sun</div>\n      <svg id=\"line-chart\" viewBox=\"0 0 480 260\" width=\"100%\" height=\"260\" role=\"img\" aria-label=\"Line chart of daily deploy counts for the last 7 days\"></svg>\n    </div>\n  </div>\n\n<script>\n(function () {\n  var days = [\"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\", \"Sat\", \"Sun\"];\n\n  // ---------- Bar chart: build durations (minutes) ----------\n  (function renderBarChart() {\n    var data = [12, 8, 15, 9, 20, 7, 11];\n    var svg = document.getElementById(\"bar-chart\");\n    var W = 480, H = 260;\n    var padLeft = 34, padRight = 12, padTop = 16, padBottom = 34;\n    var chartW = W - padLeft - padRight;\n    var chartH = H - padTop - padBottom;\n    var maxVal = Math.max.apply(null, data);\n    var niceMax = Math.ceil(maxVal / 5) * 5;\n\n    var ns = \"http://www.w3.org/2000/svg\";\n    function el(tag, attrs) {\n      var e = document.createElementNS(ns, tag);\n      for (var k in attrs) e.setAttribute(k, attrs[k]);\n      return e;\n    }\n\n    // gridlines + y-axis labels\n    var gridSteps = 4;\n    for (var g = 0; g <= gridSteps; g++) {\n      var val = (niceMax / gridSteps) * g;\n      var y = padTop + chartH - (val / niceMax) * chartH;\n      svg.appendChild(el(\"line\", {\n        x1: padLeft, x2: W - padRight, y1: y, y2: y, class: \"gridline\"\n      }));\n      var label = el(\"text\", { x: padLeft - 8, y: y + 4, class: \"axis-label\", \"text-anchor\": \"end\" });\n      label.textContent = Math.round(val);\n      svg.appendChild(label);\n    }\n\n    var n = data.length;\n    var slot = chartW / n;\n    var barW = slot * 0.55;\n\n    data.forEach(function (v, i) {\n      var barH = (v / niceMax) * chartH;\n      var x = padLeft + i * slot + (slot - barW) / 2;\n      var y = padTop + chartH - barH;\n\n      svg.appendChild(el(\"rect\", {\n        x: x, y: y, width: barW, height: barH, rx: 3, class: \"bar\"\n      }));\n\n      var vLabel = el(\"text\", {\n        x: x + barW / 2, y: y - 6, class: \"value-label\", \"text-anchor\": \"middle\"\n      });\n      vLabel.textContent = v;\n      svg.appendChild(vLabel);\n\n      var dLabel = el(\"text\", {\n        x: x + barW / 2, y: H - padBottom + 18, class: \"axis-label\", \"text-anchor\": \"middle\"\n      });\n      dLabel.textContent = days[i];\n      svg.appendChild(dLabel);\n    });\n  })();\n\n  // ---------- Line chart: deploy counts ----------\n  (function renderLineChart() {\n    var data = [3, 5, 2, 6, 4, 7, 3];\n    var svg = document.getElementById(\"line-chart\");\n    var W = 480, H = 260;\n    var padLeft = 30, padRight = 16, padTop = 16, padBottom = 34;\n    var chartW = W - padLeft - padRight;\n    var chartH = H - padTop - padBottom;\n    var maxVal = Math.max.apply(null, data);\n    var niceMax = Math.ceil(maxVal / 2) * 2;\n\n    var ns = \"http://www.w3.org/2000/svg\";\n    function el(tag, attrs) {\n      var e = document.createElementNS(ns, tag);\n      for (var k in attrs) e.setAttribute(k, attrs[k]);\n      return e;\n    }\n\n    var gridSteps = 4;\n    for (var g = 0; g <= gridSteps; g++) {\n      var val = (niceMax / gridSteps) * g;\n      var y = padTop + chartH - (val / niceMax) * chartH;\n      svg.appendChild(el(\"line\", {\n        x1: padLeft, x2: W - padRight, y1: y, y2: y, class: \"gridline\"\n      }));\n      var label = el(\"text\", { x: padLeft - 8, y: y + 4, class: \"axis-label\", \"text-anchor\": \"end\" });\n      label.textContent = Math.round(val);\n      svg.appendChild(label);\n    }\n\n    var n = data.length;\n    var stepX = chartW / (n - 1);\n\n    var points = data.map(function (v, i) {\n      var x = padLeft + i * stepX;\n      var y = padTop + chartH - (v / niceMax) * chartH;\n      return { x: x, y: y, v: v };\n    });\n\n    var pathD = points.map(function (p, i) {\n      return (i === 0 ? \"M\" : \"L\") + p.x.toFixed(1) + \",\" + p.y.toFixed(1);\n    }).join(\" \");\n\n    svg.appendChild(el(\"path\", {\n      d: pathD, fill: \"none\", stroke: \"#34d399\", \"stroke-width\": 2.5,\n      \"stroke-linecap\": \"round\", \"stroke-linejoin\": \"round\"\n    }));\n\n    var areaD = pathD + \" L\" + points[n - 1].x.toFixed(1) + \",\" + (padTop + chartH) +\n      \" L\" + points[0].x.toFixed(1) + \",\" + (padTop + chartH) + \" Z\";\n    svg.appendChild(el(\"path\", {\n      d: areaD, fill: \"#34d399\", opacity: \"0.12\", stroke: \"none\"\n    }));\n\n    points.forEach(function (p, i) {\n      svg.appendChild(el(\"circle\", {\n        cx: p.x, cy: p.y, r: 3.5, fill: \"#34d399\", stroke: \"#0f1420\", \"stroke-width\": 1.5\n      }));\n\n      var vLabel = el(\"text\", {\n        x: p.x, y: p.y - 10, class: \"value-label\", \"text-anchor\": \"middle\"\n      });\n      vLabel.textContent = p.v;\n      svg.appendChild(vLabel);\n\n      var dLabel = el(\"text\", {\n        x: p.x, y: H - padBottom + 18, class: \"axis-label\", \"text-anchor\": \"middle\"\n      });\n      dLabel.textContent = days[i];\n      svg.appendChild(dLabel);\n    });\n  })();\n})();\n</script>\n\n</body>\n</html>\n","structuredPatch":[],"originalFile":null,"userModified":false},"sourceToolAssistantUUID":"385e7dd7-f1a6-4ec8-a919-55c665043bd5","userType":"external","entrypoint":"sdk-cli","cwd":"/Users/boeschj/Documents/GitHub/parchment/bench/.runs/2026-07-12T14-36-59-732Z/status-dashboard/html/rep-1","sessionId":"8ac1c7cd-85d4-4a47-95b7-cea6c889a67c","version":"2.1.207","gitBranch":"main"}
