 padding: 12px;\n            text-align: left;\n            font-weight: 600;\n        }\n\n        table td {\n            padding: 12px;\n            border-bottom: 1px solid #e9ecef;\n        }\n\n        table tbody tr:last-child td {\n            border-bottom: none;\n        }\n\n        .log-level {\n            font-weight: 600;\n            padding: 2px 8px;\n            border-radius: 4px;\n            display: inline-block;\n            font-size: 12px;\n        }\n\n        .log-level.error {\n            background: #ffe0e0;\n            color: #d32f2f;\n        }\n\n        .log-level.warn {\n            background: #fff3cd;\n            color: #856404;\n        }\n\n        .log-level.info {\n            background: #d1ecf1;\n            color: #0c5460;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>📊 Live Log Dashboard</h1>\n\n        <div class=\"section\">\n            <h2>Error Rate (per minute)</h2>\n            <svg viewBox=\"0 0 800 300\" xmlns=\"http://www.w3.org/2000/svg\">\n                <!-- Grid lines -->\n                <g stroke=\"#e9ecef\" stroke-width=\"1\">\n                    <line x1=\"60\" y1=\"50\" x2=\"760\" y2=\"50\" />\n                    <line x1=\"60\" y1=\"112.5\" x2=\"760\" y2=\"112.5\" />\n                    <line x1=\"60\" y1=\"175\" x2=\"760\" y2=\"175\" />\n                    <line x1=\"60\" y1=\"237.5\" x2=\"760\" y2=\"237.5\" />\n                </g>\n\n                <!-- Axes -->\n                <g stroke=\"#666\" stroke-width=\"2\">\n                    <line x1=\"60\" y1=\"40\" x2=\"60\" y2=\"260\" />\n                    <line x1=\"60\" y1=\"260\" x2=\"760\" y2=\"260\" />\n                </g>\n\n                <!-- Y-axis labels -->\n                <g font-size=\"12\" fill=\"#666\" text-anchor=\"end\">\n                    <text x=\"50\" y=\"265\">0</text>\n                    <text x=\"50\" y=\"182.5\">1</text>\n                    <text x=\"50\" y=\"120\">2</text>\n                    <text x=\"50\" y=\"57.5\">4</text>\n                </g>\n\n                <!-- X-axis labels -->\n                <g font-size=\"12\" fill=\"#666\" text-anchor=\"middle\">\n                    <text x=\"100\" y=\"280\">1m</text>\n                    <text x=\"260\" y=\"280\">2m</text>\n                    <text x=\"420\" y=\"280\">3m</text>\n                    <text x=\"580\" y=\"280\">4m</text>\n                    <text x=\"740\" y=\"280\">5m</text>\n                </g>\n\n                <!-- Data line: 2, 3, 1, 4, 2 (scaled to SVG coordinates) -->\n                <polyline\n                    points=\"100,175 260,112.5 420,220 580,50 740,175\"\n                    fill=\"none\"\n                    stroke=\"#667eea\"\n                    stroke-width=\"3\"\n                    stroke-linecap=\"round\"\n                    stroke-linejoin=\"round\"\n                />\n\n                <!-- Data points (circles) -->\n                <circle cx=\"100\" cy=\"175\" r=\"5\" fill=\"#667eea\" stroke=\"white\" stroke-width=\"2\" />\n                <circle cx=\"260\" cy=\"112.5\" r=\"5\" fill=\"#667eea\" stroke=\"white\" stroke-width=\"2\" />\n                <circle cx=\"420\" cy=\"220\" r=\"5\" fill=\"#667eea\" stroke=\"white\" stroke-width=\"2\" />\n                <circle cx=\"580\" cy=\"50\" r=\"5\" fill=\"#667eea\" stroke=\"white\" stroke-width=\"2\" />\n                <circle cx=\"740\" cy=\"175\" r=\"5\" fill=\"#667eea\" stroke=\"white\" stroke-width=\"2\" />\n            </svg>\n        </div>\n\n        <div class=\"section\">\n            <h2>Recent Logs</h2>\n            <table>\n                <thead>\n                    <tr>\n                        <th>Level</th>\n                        <th>Message</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td><span class=\"log-level error\">ERROR</span></td>\n                        <td>db timeo