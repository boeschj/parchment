- Y-axis labels -->\n                <text class=\"axis-label\" x=\"35\" y=\"275\">0</text>\n                <text class=\"axis-label\" x=\"35\" y=\"190\">1</text>\n                <text class=\"axis-label\" x=\"35\" y=\"127\">2</text>\n                <text class=\"axis-label\" x=\"35\" y=\"65\">3</text>\n                <text class=\"axis-label\" x=\"30\" y=\"35\">4</text>\n\n                <!-- X-axis labels -->\n                <text class=\"axis-label\" x=\"48\" y=\"290\">0</text>\n                <text class=\"axis-label\" x=\"160\" y=\"290\">1</text>\n                <text class=\"axis-label\" x=\"270\" y=\"290\">2</text>\n                <text class=\"axis-label\" x=\"380\" y=\"290\">3</text>\n                <text class=\"axis-label\" x=\"470\" y=\"290\">4</text>\n\n                <!-- Data line: points (2, 3, 1, 4, 2) -->\n                <polyline class=\"data-line\" points=\"70,205 160,155 250,245 340,55 430,205\" />\n\n                <!-- Data points -->\n                <circle class=\"data-point\" cx=\"70\" cy=\"205\" r=\"4\" />\n                <circle class=\"data-point\" cx=\"160\" cy=\"155\" r=\"4\" />\n                <circle class=\"data-point\" cx=\"250\" cy=\"245\" r=\"4\" />\n                <circle class=\"data-point\" cx=\"340\" cy=\"55\" r=\"4\" />\n                <circle class=\"data-point\" cx=\"430\" cy=\"205\" r=\"4\" />\n\n                <!-- Data value labels -->\n                <text class=\"axis-label\" x=\"65\" y=\"200\">2</text>\n                <text class=\"axis-label\" x=\"155\" y=\"150\">3</text>\n                <text class=\"axis-label\" x=\"245\" y=\"240\">1</text>\n                <text class=\"axis-label\" x=\"335\" y=\"50\">4</text>\n                <text class=\"axis-label\" x=\"425\" y=\"200\">2</text>\n            </svg>\n        </div>\n\n        <div class=\"logs-section\">\n            <div class=\"chart-title\">Recent Logs</div>\n            <table>\n                <thead>\n                    <tr>\n      