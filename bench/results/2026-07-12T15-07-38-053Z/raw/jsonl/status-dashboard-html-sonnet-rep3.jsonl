: 10px;\n    padding: 20px 24px;\n  }\n  .chart-title {\n    font-size: 15px;\n    font-weight: 600;\n    margin-bottom: 16px;\n  }\n  .bar-label, .axis-label {\n    fill: var(--muted);\n    font-size: 11px;\n  }\n  .bar-value {\n    fill: var(--text);\n    font-size: 11px;\n    font-weight: 600;\n  }\n  @media (max-width: 720px) {\n    .kpi-row, .charts-row {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n</head>\n<body>\n\n<h1>CI Status Dashboard</h1>\n<p class=\"subtitle\">Last 7 days &middot; Mon&ndash;Sun</p>\n\n<div class=\"kpi-row\">\n  <div class=\"kpi-card\">\n    <div class=\"kpi-label\">Build Pass Rate</div>\n    <div class=\"kpi-value pass\">94%</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"kpi-label\">Avg Build Time</div>\n    <div class=\"kpi-value time\">4m 12s</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"kpi-label\">Open Incidents</div>\n    <div class=\"kpi-value incidents\">2</div>\n  </div>\n</div>\n\n<div class=\"charts-row\">\n\n  <div class=\"chart-card\">\n    <div class=\"chart-title\">Build Duration (minutes)</div>\n    <svg viewBox=\"0 0 400 240\" width=\"100%\" height=\"240\" xmlns=\"http://www.w3.org/2000/svg\">\n      <!-- gridlines -->\n      <line x1=\"40\" y1=\"10\" x2=\"40\" y2=\"190\" stroke=\"#2a2e38\" stroke-width=\"1\"/>\n      <line x1=\"40\" y1=\"190\" x2=\"390\" y2=\"190\" stroke=\"#2a2e38\" stroke-width=\"1\"/>\n      <line x1=\"40\" y1=\"140\" x2=\"390\" y2=\"140\" stroke=\"#22252d\" stroke-width=\"1\"/>\n      <line x1=\"40\" y1=\"90\" x2=\"390\" y2=\"90\" stroke=\"#22252d\" stroke-width=\"1\"/>\n      <line x1=\"40\" y1=\"40\" x2=\"390\" y2=\"40\" stroke=\"#22252d\" stroke-width=\"1\"/>\n      <text x=\"34\" y=\"194\" text-anchor=\"end\" class=\"axis-label\">0</text>\n      <text x=\"34\" y=\"144\" text-anchor=\"end\" class=\"axis-label\">10</text>\n      <text x=\"34\" y=\"94\" text-anchor=\"end\" class=\"axis-label\">20</text>\n\n      <!-- bars: max value 20 -> scale 8px per unit, baseline y=190 -->\n      <!-- Mon: 12 -->\n      <rect x=\"55\" y=\"94\" width=\"34\" height=\"96\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"72\" y=\"86\" text-anchor=\"middle\" class=\"bar-value\">12</text>\n      <text x=\"72\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Mon</text>\n\n      <!-- Tue: 8 -->\n      <rect x=\"103\" y=\"126\" width=\"34\" height=\"64\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"120\" y=\"118\" text-anchor=\"middle\" class=\"bar-value\">8</text>\n      <text x=\"120\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Tue</text>\n\n      <!-- Wed: 15 -->\n      <rect x=\"151\" y=\"70\" width=\"34\" height=\"120\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"168\" y=\"62\" text-anchor=\"middle\" class=\"bar-value\">15</text>\n      <text x=\"168\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Wed</text>\n\n      <!-- Thu: 9 -->\n      <rect x=\"199\" y=\"118\" width=\"34\" height=\"72\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"216\" y=\"110\" text-anchor=\"middle\" class=\"bar-value\">9</text>\n      <text x=\"216\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Thu</text>\n\n      <!-- Fri: 20 -->\n      <rect x=\"247\" y=\"30\" width=\"34\" height=\"160\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"264\" y=\"22\" text-anchor=\"middle\" class=\"bar-value\">20</text>\n      <text x=\"264\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Fri</text>\n\n      <!-- Sat: 7 -->\n      <rect x=\"295\" y=\"134\" width=\"34\" height=\"56\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"312\" y=\"126\" text-anchor=\"middle\" class=\"bar-value\">7</text>\n      <text x=\"312\" y=\"206\" text-anchor=\"middle\" class=\"bar-label\">Sat</text>\n\n      <!-- Sun: 11 -->\n      <rect x=\"343\" y=\"102\" width=\"34\" height=\"88\" fill=\"#4f8cff\" rx=\"3\"/>\n      <text x=\"360\" y=\"94\" text-anchor=\"middle\" class=\"bar-value\">11</text>\n      <text x=\"360\" y=\"206\" text-anchor=\"middle\" class=\"bar-la