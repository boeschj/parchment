exports[`golden: mixed-report compiles to the expected spec 1`] = `
{
  "elements": {
    "callout-5": {
      "children": [],
      "props": {
        "body": "Set the TTL to the sync interval, not to a guess: \`ttl: FIVE_MINUTES\`.",
        "title": "The one-line fix",
        "tone": "tip",
      },
      "type": "Callout",
    },
    "codeblock-4": {
      "children": [],
      "props": {
        "code": 
"export async function getCached(key: string): Promise<string | null> {
  const hit = await redis.get(key, { ttl: THIRTY_SECONDS });
  if (hit !== null) return hit;
  return fetchAndCache(key);
}"
,
        "highlightLines": [
          2,
        ],
        "language": "typescript",
        "title": "src/api/cache.ts",
      },
      "type": "CodeBlock",
    },
    "heading-0": {
      "children": [],
      "props": {
        "level": "h1",
        "text": "Why the invoice cache kept missing",
      },
      "type": "Heading",
    },
    "heading-2": {
      "children": [],
      "props": {
        "level": "h2",
        "text": "What happens today",
      },
