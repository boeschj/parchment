"ins\", b: b.slice(j) });\n  return segs;\n}\n\nfunction esc(s) {\n  return s.replace(/&/g, \"&amp;\").replace(/</g, \"&lt;\").replace(/>/g, \"&gt;\");\n}\n\nfunction renderWithHighlight(segs, side) {\n  let out = \"\";\n  for (const seg of segs) {\n    if (seg.type === \"eq\") {\n      out += esc(side === \"a\" ? seg.a : seg.b);\n    } else if (seg.type === \"del\" && side === \"a\") {\n      out += `<span class=\"intraline-del\">${esc(seg.a)}</span>`;\n    } else if (seg.type === \"ins\" && side === \"b\") {\n      out += `<span class=\"intraline-add\">${esc(seg.b)}</span>`;\n    }\n  }\n  return out;\n}\n\nfunction buildRows(groups) {\n  const rows = [];\n  let oldNo = 1, newNo = 1;\n\n  const emptyCell = () => ({ num: \"\", cls: \"blank\", html: \"\" });\n\n  for (const g of groups) {\n    if (g.type === \"equal\") {\n      for (const op of g.items) {\n        rows.push({\n          left: { num: oldNo++, cls: \"equal\", html: esc(op.a) },\n          right: { num: newNo++, cls: \"equal\", html: esc(op.b) },\n        });\n      }\n    } else {\n      const maxLen = Math.max(g.dels.length, g.adds.length);\n      const pairCount = Math.min(g.dels.length, g.adds.length);\n      for (let k = 0; k < maxLen; k++) {\n        const hasDel = k < g.dels.length;\n        const hasAdd = k < g.adds.length;\n        let leftHtml, rightHtml;\n        if (hasDel && hasAdd && k < pairCount) {\n          const segs = charDiff(g.dels[k], g.adds[k]);\n          leftHtml = renderWithHighlight(segs, \"a\");\n          rightHtml = renderWithHighlight(segs, \"b\");\n        } else {\n          leftHtml = hasDel ? esc(g.dels[k]) : \"\";\n          rightHtml = hasAdd ? esc(g.adds[k]) : \"\";\n        }\n        rows.push({\n          left: hasDel ? { num: oldNo++, cls: \"del\", html: leftHtml } : emptyCell(),\n          right: hasAdd ? { num: newNo++, cls: \"add\", html: rightHtml } : emptyCell(),\n        });\n      }\n    }\n  }\n  return rows;\n}\n\nfunction render() {\n  const oldLines