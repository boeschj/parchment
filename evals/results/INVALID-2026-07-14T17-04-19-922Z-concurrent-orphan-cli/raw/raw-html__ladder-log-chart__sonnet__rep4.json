        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    color-scheme: light;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 24px;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    background: #0f1115;\n    color: #e8e9ec;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    font-size: 20px;\n    font-weight: 600;\n    margin: 0 0 4px;\n    text-align: center;\n  }\n  .subtitle {\n    color: #9aa0ab;\n    font-size: 13px;\n    margin: 0 0 28px;\n    text-align: center;\n  }\n  .card {\n    background: #171a21;\n    border: 1px solid #262b35;\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    box-shadow: 0 8px 30px rgba(0,0,0,0.35);\n  }\n  .chart-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n    margin-bottom: 8px;\n  }\n  .chart-header .label {\n    font-size: 13px;\n    color: #c6cad3;\n    font-weight: 600;\n    letter-spacing: 0.02em;\n  }\n  .chart-header .meta {\n    font-size: 12px;\n    color: #6f7684;\n  }\n  svg { display: block; overflow: visible; }\n  .gridline {\n    stroke: #262b35;\n    stroke-width: 1;\n  }\n  .axis-line {\n    stroke: #3a4150;\n    stroke-width: 1;\n  }\n  .axis-label {\n    fill: #8b909c;\n    font-size: 11px;\n  }\n  .y-axis-title {\n    fill: #6f7684;\n    font-size: 11px;\n  }\n  .bar {\n    fill: #e5484d;\n    rx: 3px;\n    transition: fill 0.15s ease, opacity 0.15s ease;\n  }\n  .bar:hover {\n    fill: #ff6b6f;\n  }\n  .bar-value {\n    fill: #e8e9ec;\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .footer-stats {\n    display: flex;\n    gap: 28px;\n    justify-content: center;\n    margin-top: 24px;\n    padding-top: 16px;\n    border-top: 1px solid #262b35;\n  }\n  .stat {\n    text-align: center;\n  }\n  .stat .num {\n    font-size: 20px;\n    font-weight: 700;\n    color: #e5484d;\n  }\n  .stat .num.neutral {\n    color: #e8e9ec;\n  }\n  .stat .lbl {\n    font-size: 11px;\n    color: #8b909c;\n    margin-top: 2px;\n    letter-spacing: 0.03em;\n    text-transform: uppercase;\n  }\n  tooltip-box {\n    display: none;\n  }\n  .tooltip {\n    position: absolute;\n    pointer-events: none;\n    background: #23272f;\n    border: 1px solid #3a4150;\n    border-radius: 6px;\n    padding: 6px 10px;\n    font-size: 12px;\n    color: #e8e9ec;\n    opacity: 0;\n    transform: translate(-50%, -100%);\n    transition: opacity 0.1s ease;\n    white-space: nowrap;\n    z-index: 10;\n  }\n</style>\n</head>\n<body>\n\n  <h1>Chart the error rate over time from a log file on disk</h1>\n  <p class=\"subtitle\">logs/app.log &middot; 2026-05-11, 09:00&ndash;10:00 &middot; ERROR lines per 10-minute bucket</p>\n\n  <div class=\"card\" style=\"position: relative;\">\n    <div class=\"chart-header\">\n      <span class=\"label\">ERROR count by bucket</span>\n      <span class=\"meta\">100 lines scanned &middot; 22 ERROR</span>\n    </div>\n    <svg id=\"chart\" width=\"640\" height=\"360\" viewBox=\"0 0 640 360\"></svg>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <div class=\"footer-stats\">\n      <div class=\"stat\">\n        <div class=\"num\">22</div>\n        <div class=\"lbl\">Total errors</div>\n      </div>\n      <div class=\"stat\">\n        <div class=\"num\">09:30</div>\n        <div class=\"lbl\">Peak bucket</div>\n      </div>\n      <div class=\"stat\">\n        <div class=\"num\">11</div>\n        <div class=\"lbl\">Peak count</div>\n      </div>\n      <div class=\"stat\">\n        <div class=\"num neutral\">2.2%</div>\n        <div class=\"lbl\">Overall error rate</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n  // ERROR lines from logs/app.log bucketed into 10-minute windows starting at 09:00.\n  var buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 }\n  ];\n\n  var svg = document.getElementById(\"chart\");\n  var tooltip = document.getElementById(\"tooltip\");\n\n  var width = 640, height = 360;\n  var margin = { top: 20, right: 20, bottom: 46, left: 40 };\n  var plotW = width - margin.left - margin.right;\n  var plotH = height - margin.top - margin.bottom;\n\n  var maxVal = Math.max.apply(null, buckets.map(function (b) { return b.count; }));\n  var yMax = Math.ceil((maxVal + 1) / 2) * 2; // headroom, round to even\n\n  var ns = \"http://www.w3.org/2000/svg\";\n\n  function el(tag, attrs) {\n    var e = document.createElementNS(ns, tag);\n    for (var k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // Y gridlines + labels\n  var ySteps = 4;\n  for (var i = 0; i <= ySteps; i++) {\n    var v = Math.round((yMax / ySteps) * i);\n    var y = margin.top + plotH - (v / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: margin.left, x2: margin.left + plotW, y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    var lbl = el(\"text\", {\n      x: margin.left - 10, y: y + 4,\n      class: \"axis-label\", \"text-anchor\": \"end\"\n    });\n    lbl.textContent = v;\n    svg.appendChild(lbl);\n  }\n\n  // Axis line\n  svg.appendChild(el(\"line\", {\n    x1: margin.left, x2: margin.left + plotW,\n    y1: margin.top + plotH, y2: margin.top + plotH,\n    class: \"axis-line\"\n  }));\n\n  // Bars\n  var n = buckets.length;\n  var slot = plotW / n;\n  var barW = slot * 0.55;\n\n  buckets.forEach(function (b, i) {\n    var slotX = margin.left + i * slot;\n    var barH = (b.count / yMax) * plotH;\n    var x = slotX + (slot - barW) / 2;\n    var y = margin.top + plotH - barH;\n\n    var rect = el(\"rect\", {\n      x: x, y: y, width: barW, height: Math.max(barH, 0),\n      class: \"bar\",\n      rx: 3\n    });\n    rect.addEventListener(\"mousemove\", function (evt) {\n      var rectBox = svg.getBoundingClientRect();\n      tooltip.style.left = (evt.clientX - rectBox.left) + \"px\";\n      tooltip.style.top = (evt.clientY - rectBox.top - 10) + \"px\";\n      tooltip.style.opacity = 1;\n      tooltip.textContent = b.label + \"–\" + minutesLabel(b.label) + \"  •  \" + b.count + \" error\" + (b.count === 1 ? \"\" : \"s\");\n    });\n    rect.addEventListener(\"mouseleave\", function () {\n      tooltip.style.opacity = 0;\n    });\n    svg.appendChild(rect);\n\n    // value label above bar\n    if (b.count > 0) {\n      var val = el(\"text\", {\n        x: slotX + slot / 2, y: y - 8,\n        class: \"bar-value\"\n      });\n      val.textContent = b.count;\n      svg.appendChild(val);\n    }\n\n    // x axis label\n    var xl = el(\"text\", {\n      x: slotX + slot / 2, y: margin.top + plotH + 20,\n      class: \"axis-label\", \"text-anchor\": \"middle\"\n    });\n    xl.textContent = b.label;\n    svg.appendChild(xl);\n  });\n\n  // x axis title\n  var xTitle = el(\"text\", {\n    x: margin.left + plotW / 2, y: height - 6,\n    class: \"y-axis-title\", \"text-anchor\": \"middle\"\n  });\n  xTitle.textContent = \"Bucket start time (10-minute windows)\";\n  svg.appendChild(xTitle);\n\n  function minutesLabel(start) {\n    var parts = start.split(\":\");\n    var h = parseInt(parts[0], 10);\n    var m = parseInt(parts[1], 10) + 10;\n    if (m >= 60) { m -= 60; h += 1; }\n    return (h < 10 ? \"0\" + h : h) + \":\" + (m < 10 ? \"0\" + m : m);\n  }\n</script>\n\n</body>\n</html>\n",
