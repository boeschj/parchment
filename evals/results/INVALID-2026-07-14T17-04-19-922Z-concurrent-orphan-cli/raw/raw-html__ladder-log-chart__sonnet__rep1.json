        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    --bg: #0f1115;\n    --panel: #161923;\n    --grid: #2a2f3d;\n    --text: #e6e8ee;\n    --muted: #8b93a7;\n    --error: #e5484d;\n    --error-glow: rgba(229, 72, 77, 0.35);\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 24px;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n  }\n  .card {\n    width: 100%;\n    max-width: 780px;\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    box-shadow: 0 20px 50px rgba(0,0,0,0.35);\n  }\n  h1 {\n    font-size: 17px;\n    font-weight: 600;\n    margin: 0 0 2px;\n    letter-spacing: 0.2px;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13px;\n    margin: 0 0 22px;\n  }\n  .stats {\n    display: flex;\n    gap: 28px;\n    margin-bottom: 20px;\n  }\n  .stat .num {\n    font-size: 22px;\n    font-weight: 700;\n  }\n  .stat .num.err { color: var(--error); }\n  .stat .label {\n    font-size: 11px;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.6px;\n    margin-top: 2px;\n  }\n  svg { display: block; width: 100%; height: auto; overflow: visible; }\n  .gridline { stroke: var(--grid); stroke-width: 1; }\n  .bar {\n    fill: var(--error);\n    transition: filter 0.15s ease;\n  }\n  .bar:hover { filter: brightness(1.25); }\n  .bar-label {\n    fill: var(--text);\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-label {\n    fill: var(--muted);\n    font-size: 11px;\n    text-anchor: middle;\n  }\n  .y-tick {\n    fill: var(--muted);\n    font-size: 10px;\n    text-anchor: end;\n  }\n  .footnote {\n    color: var(--muted);\n    font-size: 11.5px;\n    margin-top: 18px;\n    padding-top: 14px;\n    border-top: 1px solid var(--grid);\n  }\n  .peak-note {\n    color: var(--error);\n    font-weight: 600;\n  }\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h1>Chart the error rate over time from a log file on disk</h1>\n  <p class=\"subtitle\">ERROR lines per 10-minute bucket &mdash; logs/app.log, 2026-05-11 09:00&ndash;10:00 UTC</p>\n\n  <div class=\"stats\">\n    <div class=\"stat\">\n      <div class=\"num err\">22</div>\n      <div class=\"label\">Total errors</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"num\">1042</div>\n      <div class=\"label\">Total requests</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"num\">2.1%</div>\n      <div class=\"label\">Error rate</div>\n    </div>\n  </div>\n\n  <svg id=\"chart\" viewBox=\"0 0 700 320\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n\n  <p class=\"footnote\">\n    Errors spike sharply after a <code>pricing</code> upstream timeout cascades into a circuit-breaker trip\n    around 09:30&ndash;09:37 (<span class=\"peak-note\">peak of 11 errors in the 09:30 bucket</span>), then recover\n    as the breaker closes near 09:40.\n  </p>\n</div>\n\n<script>\n  const buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 },\n  ];\n\n  const svg = document.getElementById(\"chart\");\n  const W = 700, H = 320;\n  const marginLeft = 32, marginRight = 12, marginTop = 16, marginBottom = 40;\n  const plotW = W - marginLeft - marginRight;\n  const plotH = H - marginTop - marginBottom;\n\n  const maxCount = Math.max(...buckets.map(b => b.count));\n  const yMax = Math.ceil((maxCount + 1) / 4) * 4;\n\n  const ns = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    const e = document.createElementNS(ns, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  const gridCount = 4;\n  for (let i = 0; i <= gridCount; i++) {\n    const y = marginTop + plotH - (plotH * i / gridCount);\n    const val = Math.round(yMax * i / gridCount);\n    svg.appendChild(el(\"line\", {\n      x1: marginLeft, x2: W - marginRight, y1: y, y2: y, class: \"gridline\"\n    }));\n    const t = el(\"text\", { x: marginLeft - 8, y: y + 3, class: \"y-tick\" });\n    t.textContent = val;\n    svg.appendChild(t);\n  }\n\n  const n = buckets.length;\n  const slot = plotW / n;\n  const barW = slot * 0.5;\n\n  buckets.forEach((b, i) => {\n    const cx = marginLeft + slot * i + slot / 2;\n    const barH = yMax === 0 ? 0 : (b.count / yMax) * plotH;\n    const y = marginTop + plotH - barH;\n\n    svg.appendChild(el(\"rect\", {\n      x: cx - barW / 2,\n      y: y,\n      width: barW,\n      height: Math.max(barH, b.count > 0 ? 2 : 0),\n      rx: 3,\n      class: \"bar\"\n    }));\n\n    if (b.count > 0) {\n      const countLabel = el(\"text\", { x: cx, y: y - 8, class: \"bar-label\" });\n      countLabel.textContent = b.count;\n      svg.appendChild(countLabel);\n    }\n\n    const axisLabel = el(\"text\", { x: cx, y: marginTop + plotH + 22, class: \"axis-label\" });\n    axisLabel.textContent = b.label;\n    svg.appendChild(axisLabel);\n  });\n\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: W - marginRight,\n    y1: marginTop + plotH, y2: marginTop + plotH,\n    class: \"gridline\"\n  }));\n</script>\n</body>\n</html>\n",
