        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Error rate over time</title>\n<style>\n  :root {\n    --bg: #0f1117;\n    --panel: #171a23;\n    --grid: #2a2e3a;\n    --text: #e6e8ef;\n    --muted: #8b90a0;\n    --bar: #e5484d;\n    --bar-hi: #ff6b6b;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 24px;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n  }\n  .card {\n    width: 100%;\n    max-width: 860px;\n    background: var(--panel);\n    border-radius: 14px;\n    padding: 28px 32px 20px;\n    box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 20px 40px rgba(0,0,0,0.35);\n  }\n  h1 {\n    font-size: 18px;\n    font-weight: 600;\n    margin: 0 0 2px;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13px;\n    margin: 0 0 24px;\n  }\n  .stats {\n    display: flex;\n    gap: 28px;\n    margin-bottom: 22px;\n  }\n  .stat .num {\n    font-size: 22px;\n    font-weight: 700;\n  }\n  .stat .lbl {\n    font-size: 11px;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    color: var(--muted);\n    margin-top: 2px;\n  }\n  svg { display: block; overflow: visible; }\n  .grid-line { stroke: var(--grid); stroke-width: 1; }\n  .axis-label { fill: var(--muted); font-size: 12px; }\n  .bar { fill: var(--bar); transition: fill 0.15s; }\n  .bar:hover { fill: var(--bar-hi); }\n  .bar-label { fill: var(--text); font-size: 12px; font-weight: 600; text-anchor: middle; }\n  .peak-tag {\n    fill: var(--bar-hi);\n    font-size: 11px;\n    font-weight: 700;\n    text-anchor: middle;\n  }\n  .footnote {\n    margin-top: 20px;\n    font-size: 12px;\n    color: var(--muted);\n    border-top: 1px solid var(--grid);\n    padding-top: 14px;\n  }\n  .footnote code {\n    background: rgba(255,255,255,0.06);\n    padding: 1px 5px;\n    border-radius: 4px;\n    font-size: 11px;\n  }\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h1>ERROR rate over time</h1>\n  <p class=\"subtitle\">logs/app.log &middot; 2026-05-11, 09:00&ndash;10:00 &middot; bucketed in 10-minute windows</p>\n\n  <div class=\"stats\">\n    <div class=\"stat\"><div class=\"num\">22</div><div class=\"lbl\">Total errors</div></div>\n    <div class=\"stat\"><div class=\"num\">1042</div><div class=\"lbl\">Total requests</div></div>\n    <div class=\"stat\"><div class=\"num\">2.1%</div><div class=\"lbl\">Error rate</div></div>\n    <div class=\"stat\"><div class=\"num\">09:30</div><div class=\"lbl\">Peak bucket</div></div>\n  </div>\n\n  <svg id=\"chart\" width=\"796\" height=\"300\" viewBox=\"0 0 796 300\"></svg>\n\n  <p class=\"footnote\">Source: <code>logs/app.log</code> (100 lines). Counts are ERROR-level log lines per bucket; bucket label marks the start of each 10-minute window.</p>\n</div>\n\n<script>\n  const buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 },\n  ];\n\n  const svg = document.getElementById(\"chart\");\n  const W = 796, H = 300;\n  const marginTop = 20, marginBottom = 40, marginLeft = 30, marginRight = 20;\n  const plotW = W - marginLeft - marginRight;\n  const plotH = H - marginTop - marginBottom;\n\n  const maxCount = Math.max(...buckets.map(b => b.count));\n  const yMax = Math.ceil((maxCount + 1) / 5) * 5;\n\n  const ns = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    const e = document.createElementNS(ns, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // gridlines + y-axis ticks\n  const ySteps = 5;\n  for (let i = 0; i <= ySteps; i++) {\n    const val = (yMax / ySteps) * i;\n    const y = marginTop + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: marginLeft, x2: W - marginRight, y1: y, y2: y,\n      class: \"grid-line\"\n    }));\n    const t = el(\"text\", {\n      x: marginLeft - 8, y: y + 4,\n      class: \"axis-label\", \"text-anchor\": \"end\"\n    });\n    t.textContent = val;\n    svg.appendChild(t);\n  }\n\n  const n = buckets.length;\n  const slot = plotW / n;\n  const barW = slot * 0.5;\n\n  buckets.forEach((b, i) => {\n    const cx = marginLeft + slot * i + slot / 2;\n    const barH = (b.count / yMax) * plotH;\n    const y = marginTop + plotH - barH;\n\n    const rect = el(\"rect\", {\n      x: cx - barW / 2, y: y,\n      width: barW, height: Math.max(barH, b.count > 0 ? 1 : 0),\n      rx: 3,\n      class: \"bar\"\n    });\n    svg.appendChild(rect);\n\n    const title = el(\"title\", {});\n    title.textContent = `${b.label} — ${b.count} error${b.count === 1 ? \"\" : \"s\"}`;\n    rect.appendChild(title);\n\n    const countLabel = el(\"text\", {\n      x: cx, y: y - 8,\n      class: \"bar-label\"\n    });\n    countLabel.textContent = b.count;\n    svg.appendChild(countLabel);\n\n    if (b.count === maxCount && maxCount > 0) {\n      const peak = el(\"text\", {\n        x: cx, y: y - 24,\n        class: \"peak-tag\"\n      });\n      peak.textContent = \"peak\";\n      svg.appendChild(peak);\n    }\n\n    const xLabel = el(\"text\", {\n      x: cx, y: marginTop + plotH + 20,\n      class: \"axis-label\",\n      \"text-anchor\": \"middle\"\n    });\n    xLabel.textContent = b.label;\n    svg.appendChild(xLabel);\n  });\n\n  // axis lines\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: marginLeft, y1: marginTop, y2: marginTop + plotH,\n    class: \"grid-line\"\n  }));\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: W - marginRight, y1: marginTop + plotH, y2: marginTop + plotH,\n    class: \"grid-line\"\n  }));\n</script>\n</body>\n</html>\n",
