        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    color-scheme: light;\n  }\n  body {\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    background: #0f1117;\n    color: #e6e8ee;\n    margin: 0;\n    padding: 2rem;\n  }\n  h1 {\n    font-size: 1.25rem;\n    font-weight: 600;\n    margin: 0 0 0.25rem 0;\n  }\n  .subtitle {\n    color: #9aa0ac;\n    font-size: 0.9rem;\n    margin: 0 0 2rem 0;\n  }\n  .card {\n    background: #171a23;\n    border: 1px solid #262b38;\n    border-radius: 12px;\n    padding: 1.5rem 1.75rem 1rem;\n    max-width: 760px;\n  }\n  .chart-title {\n    font-size: 0.95rem;\n    font-weight: 600;\n    color: #e6e8ee;\n    margin: 0 0 1.25rem 0;\n  }\n  svg {\n    display: block;\n    overflow: visible;\n  }\n  .bar {\n    fill: #ef4444;\n    transition: fill 0.15s ease, opacity 0.15s ease;\n  }\n  .bar:hover {\n    fill: #f87171;\n  }\n  .bar-label {\n    fill: #e6e8ee;\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-label {\n    fill: #9aa0ac;\n    font-size: 11px;\n    text-anchor: middle;\n  }\n  .axis-line {\n    stroke: #2f3644;\n    stroke-width: 1;\n  }\n  .gridline {\n    stroke: #20242f;\n    stroke-width: 1;\n  }\n  .y-axis-label {\n    fill: #6b7280;\n    font-size: 10px;\n    text-anchor: end;\n  }\n  .summary {\n    display: flex;\n    gap: 2rem;\n    margin-top: 1.5rem;\n    padding-top: 1rem;\n    border-top: 1px solid #262b38;\n    color: #9aa0ac;\n    font-size: 0.85rem;\n  }\n  .summary strong {\n    color: #e6e8ee;\n    font-size: 1rem;\n    display: block;\n  }\n  .summary div {\n    display: flex;\n    flex-direction: column;\n    gap: 0.15rem;\n  }\n  .peak {\n    color: #f87171 !important;\n  }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<p class=\"subtitle\">ERROR lines per 10-minute bucket &mdash; logs/app.log (2026-05-11, 09:00&ndash;10:00 UTC)</p>\n\n<div class=\"card\">\n  <p class=\"chart-title\">ERROR count by bucket</p>\n  <svg id=\"chart\" width=\"720\" height=\"320\" viewBox=\"0 0 720 320\"></svg>\n\n  <div class=\"summary\">\n    <div>\n      <strong id=\"total-errors\">22</strong>\n      total ERROR lines\n    </div>\n    <div>\n      <strong class=\"peak\" id=\"peak-bucket\">09:30 (11)</strong>\n      peak bucket\n    </div>\n    <div>\n      <strong>60</strong>\n      minute window\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  var data = [\n    { bucket: \"09:00\", count: 0 },\n    { bucket: \"09:10\", count: 1 },\n    { bucket: \"09:20\", count: 5 },\n    { bucket: \"09:30\", count: 11 },\n    { bucket: \"09:40\", count: 4 },\n    { bucket: \"09:50\", count: 1 }\n  ];\n\n  var svg = document.getElementById(\"chart\");\n  var W = 720, H = 320;\n  var margin = { top: 20, right: 20, bottom: 40, left: 34 };\n  var plotW = W - margin.left - margin.right;\n  var plotH = H - margin.top - margin.bottom;\n\n  var maxCount = Math.max.apply(null, data.map(function (d) { return d.count; }));\n  var yMax = Math.ceil((maxCount + 1) / 2) * 2; // round up a bit for headroom\n\n  var barGap = 18;\n  var barW = (plotW - barGap * (data.length - 1)) / data.length;\n\n  var ns = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    var e = document.createElementNS(ns, tag);\n    for (var k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // Y gridlines + labels\n  var yTicks = 4;\n  for (var i = 0; i <= yTicks; i++) {\n    var val = Math.round((yMax / yTicks) * i);\n    var y = margin.top + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: margin.left, x2: margin.left + plotW,\n      y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    var label = el(\"text\", {\n      x: margin.left - 8, y: y + 4,\n      class: \"y-axis-label\"\n    });\n    label.textContent = val;\n    svg.appendChild(label);\n  }\n\n  // Baseline axis\n  svg.appendChild(el(\"line\", {\n    x1: margin.left, x2: margin.left + plotW,\n    y1: margin.top + plotH, y2: margin.top + plotH,\n    class: \"axis-line\"\n  }));\n\n  data.forEach(function (d, idx) {\n    var x = margin.left + idx * (barW + barGap);\n    var barH = yMax === 0 ? 0 : (d.count / yMax) * plotH;\n    var y = margin.top + plotH - barH;\n\n    var rect = el(\"rect\", {\n      x: x, y: y,\n      width: barW, height: barH,\n      rx: 3,\n      class: \"bar\"\n    });\n    var titleEl = el(\"title\", {});\n    titleEl.textContent = d.bucket + \" – \" + d.count + \" ERROR\" + (d.count === 1 ? \"\" : \"s\");\n    rect.appendChild(titleEl);\n    svg.appendChild(rect);\n\n    if (d.count > 0) {\n      var countLabel = el(\"text\", {\n        x: x + barW / 2, y: y - 8,\n        class: \"bar-label\"\n      });\n      countLabel.textContent = d.count;\n      svg.appendChild(countLabel);\n    }\n\n    var xLabel = el(\"text\", {\n      x: x + barW / 2, y: margin.top + plotH + 20,\n      class: \"axis-label\"\n    });\n    xLabel.textContent = d.bucket;\n    svg.appendChild(xLabel);\n  });\n})();\n</script>\n\n</body>\n</html>\n",
