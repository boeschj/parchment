n    border: 1px solid var(--grid);\n    border-radius: 6px;\n    padding: 6px 10px;\n    font-size: 12px;\n    color: var(--text);\n    opacity: 0;\n    transform: translate(-50%, -110%);\n    transition: opacity 0.1s ease;\n    white-space: nowrap;\n    z-index: 10;\n  }\n  footer {\n    margin-top: 18px;\n    font-size: 11px;\n    color: var(--muted);\n    text-align: center;\n    max-width: 720px;\n  }\n  code { color: var(--accent); }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<p class=\"subtitle\">ERROR lines per 10-minute bucket &mdash; logs/app.log, 2026-05-11 09:00&ndash;10:00 UTC</p>\n\n<div class=\"panel\">\n  <div class=\"stats\" id=\"stats\"></div>\n  <svg id=\"chart\" width=\"656\" height=\"320\"></svg>\n</div>\n\n<footer>Bucketed by log line timestamp, right-open intervals <code>[HH:MM, HH:MM+10)</code>. 100 lines parsed on load; no external requests.</footer>\n\n<div id=\"tooltip\"></div>\n\n<script>\n// ---- Embedded source log (verbatim) ----\nconst RAW_LOG = `2026-05-11T09:00:04.182Z INFO  [server] server_listening port=8080 timeout_ms=15000\n2026-05-11T09:00:04.196Z INFO  [store] inventory_snapshot_loaded items=1284 duration_ms=312\n2026-05-11T09:00:05.044Z INFO  [pricing] upstream_connected host=pricing.internal pool=8\n2026-05-11T09:01:12.663Z INFO  [http] request_completed method=GET path=/healthz status=200 duration_ms=3\n2026-05-11T09:01:47.028Z INFO  [http] request_completed method=GET path=/catalog status=200 duration_ms=142 cache=miss\n2026-05-11T09:02:19.517Z INFO  [http] request_completed method=GET path=/catalog status=200 duration_ms=11 cache=hit\n2026-05-11T09:03:02.884Z INFO  [http] request_completed method=POST path=/catalog status=201 duration_ms=204 sku=KTL-4417\n2026-05-11T09:03:41.330Z INFO  [cache] catalog_cache_invalidated reason=item_created keys=6\n2026-05-11T09:04:15.902Z INFO  [http] request_completed method=GET path=/catalog/8f21 status=200 duration_ms=37\n2026-05-11T09