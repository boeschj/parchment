        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Error rate over time</title>\n<style>\n  :root {\n    --bg: #0f1116;\n    --panel: #171a21;\n    --grid: #2a2e3a;\n    --text: #e6e8ee;\n    --muted: #9aa1b1;\n    --bar: #e5533d;\n    --bar-top: #ff7a5c;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n    padding: 40px 20px;\n  }\n  .card {\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    width: 100%;\n    max-width: 760px;\n    box-shadow: 0 8px 30px rgba(0,0,0,0.35);\n  }\n  h1 {\n    font-size: 17px;\n    font-weight: 600;\n    margin: 0 0 2px;\n    letter-spacing: 0.2px;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13px;\n    margin: 0 0 22px;\n  }\n  .stats {\n    display: flex;\n    gap: 22px;\n    margin-bottom: 18px;\n    font-size: 13px;\n    color: var(--muted);\n  }\n  .stats b {\n    color: var(--text);\n    font-size: 16px;\n    display: block;\n    font-weight: 700;\n  }\n  .bar-fill { fill: var(--bar); }\n  .bar-fill:hover { fill: var(--bar-top); }\n  .bar-label {\n    fill: var(--text);\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-label {\n    fill: var(--muted);\n    font-size: 11px;\n    text-anchor: middle;\n  }\n  .gridline { stroke: var(--grid); stroke-width: 1; }\n  .axis-line { stroke: #3a3f4d; stroke-width: 1; }\n  .ytick { fill: var(--muted); font-size: 10px; text-anchor: end; }\n  .caption {\n    margin-top: 14px;\n    font-size: 12px;\n    color: var(--muted);\n    border-top: 1px solid var(--grid);\n    padding-top: 12px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"card\">\n    <h1>Chart the error rate over time from a log file on disk</h1>\n    <p class=\"subtitle\">logs/app.log &middot; 2026-05-11 &middot; ERROR lines per 10-minute bucket</p>\n\n    <div class=\"stats\">\n      <div><b>22</b>total errors</div>\n      <div><b>1042</b>total requests (per hourly_summary)</div>\n      <div><b>09:30</b>peak bucket (11 errors)</div>\n    </div>\n\n    <svg id=\"chart\" viewBox=\"0 0 700 320\" width=\"100%\" height=\"320\"></svg>\n\n    <p class=\"caption\">\n      Buckets span 09:00&ndash;10:00 in 10-minute windows, labelled by bucket start time.\n      Counts reflect lines matching <code>ERROR</code> in the application log.\n    </p>\n  </div>\n\n<script>\n(function () {\n  var buckets = [\"09:00\", \"09:10\", \"09:20\", \"09:30\", \"09:40\", \"09:50\"];\n  var counts  = [0, 1, 5, 11, 4, 1];\n\n  var svg = document.getElementById(\"chart\");\n  var W = 700, H = 320;\n  var marginLeft = 34, marginRight = 16, marginTop = 16, marginBottom = 46;\n  var plotW = W - marginLeft - marginRight;\n  var plotH = H - marginTop - marginBottom;\n\n  var maxVal = Math.max.apply(null, counts);\n  var yMax = Math.ceil((maxVal + 1) / 2) * 2; // round up to a clean even number\n  var yStep = yMax / 4;\n\n  function ns(tag) { return document.createElementNS(\"http://www.w3.org/2000/svg\", tag); }\n\n  // Gridlines + y-axis ticks\n  for (var i = 0; i <= 4; i++) {\n    var val = i * yStep;\n    var y = marginTop + plotH - (val / yMax) * plotH;\n\n    var line = ns(\"line\");\n    line.setAttribute(\"x1\", marginLeft);\n    line.setAttribute(\"x2\", W - marginRight);\n    line.setAttribute(\"y1\", y);\n    line.setAttribute(\"y2\", y);\n    line.setAttribute(\"class\", \"gridline\");\n    svg.appendChild(line);\n\n    var tick = ns(\"text\");\n    tick.setAttribute(\"x\", marginLeft - 8);\n    tick.setAttribute(\"y\", y + 3);\n    tick.setAttribute(\"class\", \"ytick\");\n    tick.textContent = Math.round(val);\n    svg.appendChild(tick);\n  }\n\n  // Axis baseline\n  var axisLine = ns(\"line\");\n  axisLine.setAttribute(\"x1\", marginLeft);\n  axisLine.setAttribute(\"x2\", W - marginRight);\n  axisLine.setAttribute(\"y1\", marginTop + plotH);\n  axisLine.setAttribute(\"y2\", marginTop + plotH);\n  axisLine.setAttribute(\"class\", \"axis-line\");\n  svg.appendChild(axisLine);\n\n  // Bars\n  var n = buckets.length;\n  var slot = plotW / n;\n  var barWidth = slot * 0.55;\n\n  for (var j = 0; j < n; j++) {\n    var count = counts[j];\n    var barHeight = (count / yMax) * plotH;\n    var x = marginLeft + j * slot + (slot - barWidth) / 2;\n    var y2 = marginTop + plotH - barHeight;\n\n    var rect = ns(\"rect\");\n    rect.setAttribute(\"x\", x);\n    rect.setAttribute(\"y\", y2);\n    rect.setAttribute(\"width\", barWidth);\n    rect.setAttribute(\"height\", barHeight);\n    rect.setAttribute(\"rx\", 3);\n    rect.setAttribute(\"class\", \"bar-fill\");\n\n    var titleEl = ns(\"title\");\n    titleEl.textContent = buckets[j] + \"–\" + tenLater(buckets[j]) + \": \" + count + \" error\" + (count === 1 ? \"\" : \"s\");\n    rect.appendChild(titleEl);\n\n    svg.appendChild(rect);\n\n    // value label above bar\n    var valLabel = ns(\"text\");\n    valLabel.setAttribute(\"x\", x + barWidth / 2);\n    valLabel.setAttribute(\"y\", y2 - 6);\n    valLabel.setAttribute(\"class\", \"bar-label\");\n    valLabel.textContent = count;\n    svg.appendChild(valLabel);\n\n    // x-axis label\n    var xLabel = ns(\"text\");\n    xLabel.setAttribute(\"x\", x + barWidth / 2);\n    xLabel.setAttribute(\"y\", marginTop + plotH + 20);\n    xLabel.setAttribute(\"class\", \"axis-label\");\n    xLabel.textContent = buckets[j];\n    svg.appendChild(xLabel);\n  }\n\n  function tenLater(hhmm) {\n    var parts = hhmm.split(\":\");\n    var h = parseInt(parts[0], 10);\n    var m = parseInt(parts[1], 10) + 10;\n    if (m >= 60) { m -= 60; h += 1; }\n    return (h < 10 ? \"0\" + h : h) + \":\" + (m < 10 ? \"0\" + m : m);\n  }\n})();\n</script>\n</body>\n</html>\n",
