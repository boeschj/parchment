        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    color-scheme: dark;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 24px;\n    background: #0e1116;\n    color: #e6e6e6;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    font-size: 20px;\n    font-weight: 600;\n    margin: 0 0 4px;\n    text-align: center;\n  }\n  p.subtitle {\n    margin: 0 0 28px;\n    color: #9aa4b2;\n    font-size: 13px;\n    text-align: center;\n  }\n  .chart-wrap {\n    background: #161b22;\n    border: 1px solid #262c36;\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    box-shadow: 0 8px 30px rgba(0,0,0,0.35);\n  }\n  svg { display: block; }\n  .bar {\n    fill: #ef5350;\n  }\n  .bar:hover {\n    fill: #ff7b76;\n  }\n  .bar-label {\n    fill: #e6e6e6;\n    font-size: 13px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-label {\n    fill: #9aa4b2;\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .axis-line {\n    stroke: #33394a;\n    stroke-width: 1;\n  }\n  .grid-line {\n    stroke: #232a35;\n    stroke-width: 1;\n  }\n  .y-tick {\n    fill: #6d7686;\n    font-size: 11px;\n    text-anchor: end;\n  }\n  .summary {\n    margin-top: 22px;\n    font-size: 13px;\n    color: #9aa4b2;\n    text-align: center;\n  }\n  .summary strong {\n    color: #ef5350;\n  }\n  table.data {\n    margin-top: 24px;\n    border-collapse: collapse;\n    font-size: 13px;\n  }\n  table.data caption {\n    color: #9aa4b2;\n    font-size: 12px;\n    margin-bottom: 8px;\n    text-align: left;\n  }\n  table.data th, table.data td {\n    padding: 4px 14px;\n    text-align: right;\n    border-bottom: 1px solid #232a35;\n  }\n  table.data th:first-child, table.data td:first-child {\n    text-align: left;\n  }\n  table.data th {\n    color: #9aa4b2;\n    font-weight: 600;\n  }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<p class=\"subtitle\">logs/app.log &middot; 100 lines &middot; 2026-05-11 09:00&ndash;10:00 &middot; 22 ERROR lines</p>\n\n<div class=\"chart-wrap\">\n  <svg id=\"chart\" width=\"560\" height=\"360\" viewBox=\"0 0 560 360\"></svg>\n</div>\n\n<div class=\"summary\">Peak error rate: <strong>11 errors</strong> in the 09:30 bucket</div>\n\n<table class=\"data\">\n  <caption>ERROR count by ten-minute bucket</caption>\n  <thead>\n    <tr><th>Bucket start</th><th>Errors</th></tr>\n  </thead>\n  <tbody id=\"data-body\"></tbody>\n</table>\n\n<script>\n  const buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 },\n  ];\n\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const svg = document.getElementById(\"chart\");\n\n  const width = 560, height = 360;\n  const margin = { top: 20, right: 20, bottom: 50, left: 40 };\n  const plotW = width - margin.left - margin.right;\n  const plotH = height - margin.top - margin.bottom;\n\n  const maxCount = Math.max(...buckets.map(b => b.count));\n  const yMax = Math.ceil((maxCount + 1) / 2) * 2; // headroom, even ticks\n  const barSlot = plotW / buckets.length;\n  const barWidth = barSlot * 0.55;\n\n  function el(tag, attrs) {\n    const e = document.createElementNS(svgNS, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // gridlines + y ticks\n  const yTickCount = 5;\n  for (let i = 0; i <= yTickCount; i++) {\n    const val = Math.round((yMax / yTickCount) * i);\n    const y = margin.top + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: margin.left, x2: margin.left + plotW, y1: y, y2: y, class: \"grid-line\"\n    }));\n    const t = el(\"text\", { x: margin.left - 8, y: y + 4, class: \"y-tick\" });\n    t.textContent = val;\n    svg.appendChild(t);\n  }\n\n  // axis line\n  svg.appendChild(el(\"line\", {\n    x1: margin.left, x2: margin.left + plotW,\n    y1: margin.top + plotH, y2: margin.top + plotH,\n    class: \"axis-line\"\n  }));\n\n  const tbody = document.getElementById(\"data-body\");\n\n  buckets.forEach((b, i) => {\n    const x = margin.left + i * barSlot + (barSlot - barWidth) / 2;\n    const barH = (b.count / yMax) * plotH;\n    const y = margin.top + plotH - barH;\n\n    const rect = el(\"rect\", {\n      x, y, width: barWidth, height: Math.max(barH, 0),\n      rx: 3, ry: 3, class: \"bar\"\n    });\n    const title = el(\"title\");\n    title.textContent = `${b.label} — ${b.count} error${b.count === 1 ? \"\" : \"s\"}`;\n    rect.appendChild(title);\n    svg.appendChild(rect);\n\n    if (b.count > 0) {\n      const countLabel = el(\"text\", {\n        x: x + barWidth / 2, y: y - 6, class: \"bar-label\"\n      });\n      countLabel.textContent = b.count;\n      svg.appendChild(countLabel);\n    }\n\n    const xLabel = el(\"text\", {\n      x: x + barWidth / 2, y: margin.top + plotH + 20, class: \"axis-label\"\n    });\n    xLabel.textContent = b.label;\n    svg.appendChild(xLabel);\n\n    const tr = document.createElement(\"tr\");\n    tr.innerHTML = `<td>${b.label}</td><td>${b.count}</td>`;\n    tbody.appendChild(tr);\n  });\n</script>\n\n</body>\n</html>\n",
