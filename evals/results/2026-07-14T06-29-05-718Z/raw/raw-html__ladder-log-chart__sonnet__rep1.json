        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Error rate over time</title>\n<style>\n  :root {\n    --bg: #0f1216;\n    --panel: #171b21;\n    --grid: #2a2f38;\n    --text: #e6e9ef;\n    --muted: #8b93a1;\n    --bar: #e5484d;\n    --bar-top: #ff6b6f;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 20px;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n  }\n  .card {\n    width: 100%;\n    max-width: 780px;\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n  }\n  h1 {\n    font-size: 18px;\n    font-weight: 600;\n    margin: 0 0 2px;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13px;\n    margin: 0 0 24px;\n  }\n  .chart-wrap {\n    width: 100%;\n  }\n  svg {\n    width: 100%;\n    height: auto;\n    overflow: visible;\n    font-family: inherit;\n  }\n  .gridline {\n    stroke: var(--grid);\n    stroke-width: 1;\n  }\n  .axis-label {\n    fill: var(--muted);\n    font-size: 11px;\n  }\n  .bucket-label {\n    fill: var(--muted);\n    font-size: 12px;\n  }\n  .value-label {\n    fill: var(--text);\n    font-size: 12px;\n    font-weight: 600;\n  }\n  .bar {\n    fill: var(--bar);\n  }\n  .bar:hover {\n    fill: var(--bar-top);\n  }\n  .axis-line {\n    stroke: var(--grid);\n    stroke-width: 1;\n  }\n  .footer {\n    margin-top: 18px;\n    padding-top: 14px;\n    border-top: 1px solid var(--grid);\n    display: flex;\n    justify-content: space-between;\n    color: var(--muted);\n    font-size: 12px;\n  }\n  .footer strong {\n    color: var(--text);\n  }\n</style>\n</head>\n<body>\n  <div class=\"card\">\n    <h1>Chart the error rate over time from a log file on disk</h1>\n    <p class=\"subtitle\">logs/app.log &middot; 2026-05-11 09:00&ndash;10:00 UTC &middot; ERROR lines per 10-minute bucket</p>\n\n    <div class=\"chart-wrap\">\n      <svg id=\"chart\" viewBox=\"0 0 700 340\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n    </div>\n\n    <div class=\"footer\">\n      <span>Total lines parsed: <strong>100</strong></span>\n      <span>Total ERROR lines: <strong>22</strong></span>\n      <span>Overall error rate: <strong>22.0%</strong></span>\n    </div>\n  </div>\n\n<script>\n  const buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 },\n  ];\n\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const svg = document.getElementById(\"chart\");\n\n  const width = 700;\n  const height = 340;\n  const marginTop = 16;\n  const marginBottom = 46;\n  const marginLeft = 34;\n  const marginRight = 16;\n\n  const plotW = width - marginLeft - marginRight;\n  const plotH = height - marginTop - marginBottom;\n\n  const maxCount = Math.max(...buckets.map(b => b.count));\n  const yMax = Math.ceil((maxCount + 1) / 2) * 2; // round up to nice even number\n  const yTicks = 4;\n\n  function el(tag, attrs) {\n    const e = document.createElementNS(svgNS, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // gridlines + y-axis labels\n  for (let i = 0; i <= yTicks; i++) {\n    const val = Math.round((yMax / yTicks) * i);\n    const y = marginTop + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      class: \"gridline\",\n      x1: marginLeft, x2: width - marginRight,\n      y1: y, y2: y\n    }));\n    const t = el(\"text\", {\n      class: \"axis-label\",\n      x: marginLeft - 8, y: y + 4,\n      \"text-anchor\": \"end\"\n    });\n    t.textContent = val;\n    svg.appendChild(t);\n  }\n\n  // axis line at y=0\n  svg.appendChild(el(\"line\", {\n    class: \"axis-line\",\n    x1: marginLeft, x2: width - marginRight,\n    y1: marginTop + plotH, y2: marginTop + plotH\n  }));\n\n  const n = buckets.length;\n  const slot = plotW / n;\n  const barW = slot * 0.5;\n\n  buckets.forEach((b, i) => {\n    const slotX = marginLeft + i * slot;\n    const barH = yMax === 0 ? 0 : (b.count / yMax) * plotH;\n    const x = slotX + (slot - barW) / 2;\n    const y = marginTop + plotH - barH;\n\n    const rect = el(\"rect\", {\n      class: \"bar\",\n      x: x,\n      y: y,\n      width: barW,\n      height: barH,\n      rx: 3\n    });\n    svg.appendChild(rect);\n\n    const valLabel = el(\"text\", {\n      class: \"value-label\",\n      x: x + barW / 2,\n      y: y - 8,\n      \"text-anchor\": \"middle\"\n    });\n    valLabel.textContent = b.count;\n    svg.appendChild(valLabel);\n\n    const bucketLabel = el(\"text\", {\n      class: \"bucket-label\",\n      x: slotX + slot / 2,\n      y: marginTop + plotH + 22,\n      \"text-anchor\": \"middle\"\n    });\n    bucketLabel.textContent = b.label;\n    svg.appendChild(bucketLabel);\n  });\n</script>\n</body>\n</html>\n",
