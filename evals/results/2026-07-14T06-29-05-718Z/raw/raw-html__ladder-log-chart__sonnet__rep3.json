x1: marginLeft, x2: W - marginRight, y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    const label = el(\"text\", {\n      x: marginLeft - 8, y: y + 4, class: \"tick-label\", \"text-anchor\": \"end\"\n    });\n    label.textContent = Math.round(val);\n    svg.appendChild(label);\n  }\n\n  // bars\n  data.forEach((d, i) => {\n    const x = marginLeft + i * (barW + gap);\n    const barH = yMax === 0 ? 0 : (d.count / yMax) * plotH;\n    const y = marginTop + plotH - barH;\n\n    const rect = el(\"rect\", {\n      x, y, width: barW, height: Math.max(barH, 1),\n      rx: 4, ry: 4, class: \"bar\"\n    });\n    svg.appendChild(rect);\n\n    const valLabel = el(\"text\", {\n      x: x + barW / 2, y: y - 8, class: \"value-label\"\n    });\n    valLabel.textContent = d.count;\n    svg.appendChild(valLabel);\n\n    const tick = el(\"text\", {\n      x: x + barW / 2, y: marginTop + plotH + 20, class: \"tick-label\"\n    });\n    tick.textContent = d.bucket;\n    svg.appendChild(tick);\n  });\n\n  // axis titles\n  const xTitle = el(\"text\", {\n    x: marginLeft + plotW / 2, y: H - 4, class: \"axis-title\"\n  });\n  xTitle.textContent = \"Bucket start time (UTC)\";\n  svg.appendChild(xTitle);\n\n  const yTitle = el(\"text\", {\n    x: -(marginTop + plotH / 2), y: 14,\n    class: \"axis-title\", transform: \"rotate(-90)\"\n  });\n  yTitle.textContent = \"ERROR lines\";\n  svg.appendChild(yTitle);\n</script>\n</body>\n</html>\n"
