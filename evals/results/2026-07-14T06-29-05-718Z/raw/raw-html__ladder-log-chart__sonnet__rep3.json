        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    --bg: #0f1115;\n    --panel: #171a21;\n    --grid: #2a2e38;\n    --text: #e6e8ec;\n    --muted: #9aa1ac;\n    --bar: #e5484d;\n    --bar-top: #ff6b6f;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n    padding: 40px 20px;\n  }\n  .card {\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    width: 720px;\n    max-width: 100%;\n  }\n  h1 {\n    font-size: 18px;\n    margin: 0 0 2px;\n    font-weight: 600;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13px;\n    margin: 0 0 22px;\n  }\n  svg {\n    width: 100%;\n    height: auto;\n    overflow: visible;\n    font-family: inherit;\n  }\n  .gridline {\n    stroke: var(--grid);\n    stroke-width: 1;\n  }\n  .axis-label {\n    fill: var(--muted);\n    font-size: 12px;\n  }\n  .bar {\n    fill: var(--bar);\n    transition: fill 0.15s ease;\n  }\n  .bar:hover {\n    fill: var(--bar-top);\n  }\n  .value-label {\n    fill: var(--text);\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .tick-label {\n    fill: var(--muted);\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .axis-title {\n    fill: var(--muted);\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .stats {\n    display: flex;\n    gap: 28px;\n    margin-top: 18px;\n    padding-top: 16px;\n    border-top: 1px solid var(--grid);\n  }\n  .stat .num {\n    font-size: 20px;\n    font-weight: 700;\n  }\n  .stat .lbl {\n    font-size: 12px;\n    color: var(--muted);\n    margin-top: 2px;\n  }\n  .stat.err .num { color: var(--bar); }\n</style>\n</head>\n<body>\n<div class=\"card\">\n  <h1>Error rate over time</h1>\n  <p class=\"subtitle\">logs/app.log — ERROR lines per 10-minute bucket, 2026-05-11 09:00&ndash;10:00 UTC</p>\n\n  <svg id=\"chart\" viewBox=\"0 0 660 320\"></svg>\n\n  <div class=\"stats\">\n    <div class=\"stat err\">\n      <div class=\"num\">22</div>\n      <div class=\"lbl\">total errors</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"num\">100</div>\n      <div class=\"lbl\">total log lines</div>\n    </div>\n    <div class=\"stat\">\n      <div class=\"num\">09:30</div>\n      <div class=\"lbl\">peak bucket (11 errors)</div>\n    </div>\n  </div>\n</div>\n\n<script>\n  // Bucket start times (10-minute windows) and ERROR line counts,\n  // derived from counting ERROR-level lines in logs/app.log by timestamp.\n  const data = [\n    { bucket: \"09:00\", count: 0 },\n    { bucket: \"09:10\", count: 1 },\n    { bucket: \"09:20\", count: 5 },\n    { bucket: \"09:30\", count: 11 },\n    { bucket: \"09:40\", count: 4 },\n    { bucket: \"09:50\", count: 1 },\n  ];\n\n  const svg = document.getElementById(\"chart\");\n  const W = 660, H = 320;\n  const marginTop = 20, marginBottom = 50, marginLeft = 36, marginRight = 16;\n  const plotW = W - marginLeft - marginRight;\n  const plotH = H - marginTop - marginBottom;\n\n  const maxVal = Math.max(...data.map(d => d.count));\n  const yMax = Math.ceil((maxVal + 1) / 2) * 2; // headroom, rounded to even number\n\n  const n = data.length;\n  const gap = 18;\n  const barW = (plotW - gap * (n - 1)) / n;\n\n  const ns = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    const e = document.createElementNS(ns, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // gridlines + y-axis ticks\n  const yTickCount = 4;\n  for (let i = 0; i <= yTickCount; i++) {\n    const val = (yMax / yTickCount) * i;\n    const y = marginTop + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: marginLeft, x2: W - marginRight, y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    const label = el(\"text\", {\n      x: marginLeft - 8, y: y + 4, class: \"tick-label\", \"text-anchor\": \"end\"\n    });\n    label.textContent = Math.round(val);\n    svg.appendChild(label);\n  }\n\n  // bars\n  data.forEach((d, i) => {\n    const x = marginLeft + i * (barW + gap);\n    const barH = yMax === 0 ? 0 : (d.count / yMax) * plotH;\n    const y = marginTop + plotH - barH;\n\n    const rect = el(\"rect\", {\n      x, y, width: barW, height: Math.max(barH, 1),\n      rx: 4, ry: 4, class: \"bar\"\n    });\n    svg.appendChild(rect);\n\n    const valLabel = el(\"text\", {\n      x: x + barW / 2, y: y - 8, class: \"value-label\"\n    });\n    valLabel.textContent = d.count;\n    svg.appendChild(valLabel);\n\n    const tick = el(\"text\", {\n      x: x + barW / 2, y: marginTop + plotH + 20, class: \"tick-label\"\n    });\n    tick.textContent = d.bucket;\n    svg.appendChild(tick);\n  });\n\n  // axis titles\n  const xTitle = el(\"text\", {\n    x: marginLeft + plotW / 2, y: H - 4, class: \"axis-title\"\n  });\n  xTitle.textContent = \"Bucket start time (UTC)\";\n  svg.appendChild(xTitle);\n\n  const yTitle = el(\"text\", {\n    x: -(marginTop + plotH / 2), y: 14,\n    class: \"axis-title\", transform: \"rotate(-90)\"\n  });\n  yTitle.textContent = \"ERROR lines\";\n  svg.appendChild(yTitle);\n</script>\n</body>\n</html>\n",
