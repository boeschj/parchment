ument.querySelectorAll(\"#results-table thead th\");\n\nlet sortState = { col: null, dir: 1 };\n\nfunction render(rows) {\n  tbody.innerHTML = \"\";\n  for (const row of rows) {\n    const tr = document.createElement(\"tr\");\n    columns.forEach((col, i) => {\n      const td = document.createElement(\"td\");\n      const val = row[i];\n      if (col === \"run_id\") {\n        td.innerHTML = `<code class=\"run-id\">${val}</code>`;\n      } else if (col === \"passed\") {\n        td.innerHTML = `<span class=\"badge ${val}\">${val}</span>`;\n      } else if (typeof val === \"number\") {\n        td.textContent = val.toLocaleString();\n        td.classList.add(\"num\");\n      } else {\n        td.textContent = val;\n      }\n      tr.appendChild(td);\n    });\n    tbody.appendChild(tr);\n  }\n}\n\nfunction sortBy(colIndex, type, dir) {\n  const rows = [...data];\n  rows.sort((a, b) => {\n    let av = a[colIndex];\n    let bv = b[colIndex];\n    if (type === \"bool\") {\n      av = av ? 1 : 0;\n      bv = bv ? 1 : 0;\n    } else if (type === \"string\") {\n      av = String(av).toLowerCase();\n      bv = String(bv).toLowerCase();\n    }\n    if (av < bv) return -1 * dir;\n    if (av > bv) return 1 * dir;\n    return 0;\n  });\n  return rows;\n}\n\nheaders.forEach((th, idx) => {\n  th.addEventListener(\"click\", () => {\n    const type = th.dataset.type;\n    if (sortState.col === idx) {\n      sortState.dir *= -1;\n    } else {\n      sortState.col = idx;\n      sortState.dir = 1;\n    }\n    headers.forEach(h => h.querySelector(\".arrow\").textContent = \"\");\n    th.querySelector(\".arrow\").textContent = sortState.dir === 1 ? \"▲\" : \"▼\";\n    render(sortBy(idx, type, sortState.dir));\n  });\n});\n\nrender(data);\n</script>\n\n</body>\n</html>\n",
