7, 142, 0.15);\n    color: var(--pass);\n  }\n  .badge.false {\n    background: rgba(255, 107, 107, 0.15);\n    color: var(--fail);\n  }\n  code.run-id {\n    color: var(--muted);\n  }\n</style>\n</head>\n<body>\n\n<h1>Benchmark Results</h1>\n<p class=\"sub\">50 rows &middot; click a column header to sort</p>\n\n<div class=\"table-wrap\">\n  <table id=\"results-table\">\n    <thead>\n      <tr>\n        <th data-col=\"run_id\" data-type=\"string\">run_id<span class=\"arrow\"></span></th>\n        <th data-col=\"scenario\" data-type=\"string\">scenario<span class=\"arrow\"></span></th>\n        <th data-col=\"model\" data-type=\"string\">model<span class=\"arrow\"></span></th>\n        <th data-col=\"arm\" data-type=\"string\">arm<span class=\"arrow\"></span></th>\n        <th data-col=\"tokens_in\" data-type=\"number\">tokens_in<span class=\"arrow\"></span></th>\n        <th data-col=\"tokens_out\" data-type=\"number\">tokens_out<span class=\"arrow\"></span></th>\n        <th data-col=\"latency_ms\" data-type=\"number\">latency_ms<span class=\"arrow\"></span></th>\n        <th data-col=\"passed\" data-type=\"bool\">passed<span class=\"arrow\"></span></th>\n      </tr>\n    </thead>\n    <tbody></tbody>\n  </table>\n</div>\n\n<script>\nconst data = [\n  [\"r001\",\"git_diff_review\",\"claude-opus-4-8\",\"path_ref\",1187,742,3412,true],\n  [\"r002\",\"git_diff_review\",\"claude-opus-4-8\",\"inline_paste\",5043,698,6188,true],\n  [\"r003\",\"git_diff_review\",\"claude-opus-4-8\",\"no_render\",1094,1310,4025,false],\n  [\"r004\",\"git_diff_review\",\"claude-sonnet-4-6\",\"path_ref\",1163,689,2214,true],\n  [\"r005\",\"git_diff_review\",\"claude-sonnet-4-6\",\"inline_paste\",5019,731,4877,true],\n  [\"r006\",\"git_diff_review\",\"claude-sonnet-4-6\",\"no_render\",1071,1188,2903,false],\n  [\"r007\",\"git_diff_review\",\"claude-haiku-4-5\",\"path_ref\",1158,604,1342,true],\n  [\"r008\",\"git_diff_review\",\"claude-haiku-4-5\",\"inline_paste\",5008,1027,3560,false],\n  [\"