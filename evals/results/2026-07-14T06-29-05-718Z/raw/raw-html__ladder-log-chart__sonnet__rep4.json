        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    color-scheme: light;\n  }\n  body {\n    margin: 0;\n    padding: 40px 20px;\n    background: #0f1115;\n    color: #e6e6e6;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    font-size: 20px;\n    font-weight: 600;\n    margin: 0 0 4px;\n    text-align: center;\n  }\n  p.subtitle {\n    margin: 0 0 28px;\n    color: #9aa0a6;\n    font-size: 13px;\n    text-align: center;\n  }\n  .chart-wrap {\n    background: #171a21;\n    border: 1px solid #2a2e37;\n    border-radius: 12px;\n    padding: 28px 32px 20px;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.35);\n  }\n  svg {\n    display: block;\n    overflow: visible;\n  }\n  .bar {\n    fill: #e5484d;\n    transition: fill 0.15s ease, opacity 0.15s ease;\n  }\n  .bar:hover {\n    fill: #ff6a6f;\n  }\n  .axis-line {\n    stroke: #3a3f4b;\n    stroke-width: 1;\n  }\n  .grid-line {\n    stroke: #23262f;\n    stroke-width: 1;\n  }\n  .tick-label {\n    fill: #9aa0a6;\n    font-size: 12px;\n  }\n  .value-label {\n    fill: #e6e6e6;\n    font-size: 12px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-title {\n    fill: #c7cad1;\n    font-size: 12px;\n  }\n  .stats {\n    display: flex;\n    gap: 28px;\n    margin-top: 22px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n  .stat {\n    text-align: center;\n  }\n  .stat .num {\n    font-size: 22px;\n    font-weight: 700;\n    color: #e5484d;\n  }\n  .stat .lbl {\n    font-size: 11px;\n    color: #9aa0a6;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin-top: 2px;\n  }\n  .tooltip {\n    position: absolute;\n    pointer-events: none;\n    background: #24272f;\n    border: 1px solid #3a3f4b;\n    border-radius: 6px;\n    padding: 6px 10px;\n    font-size: 12px;\n    color: #e6e6e6;\n    opacity: 0;\n    transform: translate(-50%, -100%);\n    white-space: nowrap;\n  }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<p class=\"subtitle\">ERROR lines per 10-minute bucket &middot; logs/app.log &middot; 2026-05-11 09:00&ndash;10:00 UTC</p>\n\n<div class=\"chart-wrap\" style=\"position: relative;\">\n  <svg id=\"chart\" width=\"640\" height=\"380\"></svg>\n  <div class=\"tooltip\" id=\"tooltip\"></div>\n</div>\n\n<div class=\"stats\">\n  <div class=\"stat\"><div class=\"num\">22</div><div class=\"lbl\">Total errors</div></div>\n  <div class=\"stat\"><div class=\"num\">1042</div><div class=\"lbl\">Total requests</div></div>\n  <div class=\"stat\"><div class=\"num\">2.1%</div><div class=\"lbl\">Overall error rate</div></div>\n  <div class=\"stat\"><div class=\"num\">09:30</div><div class=\"lbl\">Peak bucket</div></div>\n</div>\n\n<script>\n(function () {\n  var buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 }\n  ];\n\n  var svg = document.getElementById(\"chart\");\n  var tooltip = document.getElementById(\"tooltip\");\n  var svgNS = \"http://www.w3.org/2000/svg\";\n\n  var W = 640, H = 380;\n  var margin = { top: 20, right: 20, bottom: 56, left: 44 };\n  var plotW = W - margin.left - margin.right;\n  var plotH = H - margin.top - margin.bottom;\n\n  var maxCount = Math.max.apply(null, buckets.map(function (b) { return b.count; }));\n  var yMax = Math.ceil((maxCount + 1) / 2) * 2;\n  var niceMax = Math.max(yMax, 2);\n\n  function makeEl(tag, attrs) {\n    var el = document.createElementNS(svgNS, tag);\n    for (var k in attrs) el.setAttribute(k, attrs[k]);\n    return el;\n  }\n\n  var g = makeEl(\"g\", { transform: \"translate(\" + margin.left + \",\" + margin.top + \")\" });\n  svg.appendChild(g);\n\n  // gridlines + y-axis ticks\n  var ySteps = 4;\n  for (var i = 0; i <= ySteps; i++) {\n    var val = Math.round((niceMax / ySteps) * i);\n    var y = plotH - (val / niceMax) * plotH;\n    g.appendChild(makeEl(\"line\", {\n      class: \"grid-line\", x1: 0, x2: plotW, y1: y, y2: y\n    }));\n    var lbl = makeEl(\"text\", {\n      class: \"tick-label\", x: -10, y: y + 4, \"text-anchor\": \"end\"\n    });\n    lbl.textContent = val;\n    g.appendChild(lbl);\n  }\n\n  // axis lines\n  g.appendChild(makeEl(\"line\", { class: \"axis-line\", x1: 0, x2: 0, y1: 0, y2: plotH }));\n  g.appendChild(makeEl(\"line\", { class: \"axis-line\", x1: 0, x2: plotW, y1: plotH, y2: plotH }));\n\n  // bars\n  var n = buckets.length;\n  var slot = plotW / n;\n  var barW = slot * 0.55;\n\n  buckets.forEach(function (b, idx) {\n    var barH = (b.count / niceMax) * plotH;\n    var x = idx * slot + (slot - barW) / 2;\n    var y = plotH - barH;\n\n    var rect = makeEl(\"rect\", {\n      class: \"bar\",\n      x: x, y: y, width: barW, height: Math.max(barH, b.count > 0 ? 1 : 0),\n      rx: 3\n    });\n    g.appendChild(rect);\n\n    rect.addEventListener(\"mousemove\", function (e) {\n      var wrapRect = svg.getBoundingClientRect();\n      tooltip.style.left = (e.clientX - wrapRect.left) + \"px\";\n      tooltip.style.top = (e.clientY - wrapRect.top - 10) + \"px\";\n      tooltip.style.opacity = 1;\n      tooltip.textContent = b.label + \"–\" + nextLabel(b.label) + \": \" + b.count + \" error\" + (b.count === 1 ? \"\" : \"s\");\n    });\n    rect.addEventListener(\"mouseleave\", function () {\n      tooltip.style.opacity = 0;\n    });\n\n    if (b.count > 0) {\n      var val = makeEl(\"text\", {\n        class: \"value-label\", x: x + barW / 2, y: y - 8\n      });\n      val.textContent = b.count;\n      g.appendChild(val);\n    }\n\n    var tick = makeEl(\"text\", {\n      class: \"tick-label\", x: x + barW / 2, y: plotH + 20, \"text-anchor\": \"middle\"\n    });\n    tick.textContent = b.label;\n    g.appendChild(tick);\n  });\n\n  function nextLabel(label) {\n    var parts = label.split(\":\");\n    var h = parseInt(parts[0], 10);\n    var m = parseInt(parts[1], 10) + 10;\n    if (m >= 60) { m -= 60; h += 1; }\n    return (h < 10 ? \"0\" + h : h) + \":\" + (m < 10 ? \"0\" + m : m);\n  }\n\n  // axis titles\n  var xTitle = makeEl(\"text\", {\n    class: \"axis-title\", x: plotW / 2, y: plotH + 44, \"text-anchor\": \"middle\"\n  });\n  xTitle.textContent = \"Bucket start time (UTC)\";\n  g.appendChild(xTitle);\n\n  var yTitle = makeEl(\"text\", {\n    class: \"axis-title\",\n    x: -plotH / 2, y: -32,\n    transform: \"rotate(-90)\",\n    \"text-anchor\": \"middle\"\n  });\n  yTitle.textContent = \"ERROR count\";\n  g.appendChild(yTitle);\n})();\n</script>\n\n</body>\n</html>\n",
