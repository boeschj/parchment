n  let sortKey = null;\n  let sortDir = 1; // 1 asc, -1 desc\n\n  function render(data) {\n    tbody.innerHTML = \"\";\n    for (const row of data) {\n      const tr = document.createElement(\"tr\");\n      row.forEach((val, i) => {\n        const td = document.createElement(\"td\");\n        const key = columns[i];\n        if (typeof val === \"number\") {\n          td.classList.add(\"num\");\n          td.textContent = val;\n        } else if (typeof val === \"boolean\") {\n          td.classList.add(val ? \"bool-true\" : \"bool-false\");\n          td.textContent = val ? \"true\" : \"false\";\n        } else {\n          td.textContent = val;\n        }\n        tr.appendChild(td);\n      });\n      tbody.appendChild(tr);\n    }\n  }\n\n  function sortBy(key, type) {\n    const idx = columns.indexOf(key);\n    if (sortKey === key) {\n      sortDir *= -1;\n    } else {\n      sortKey = key;\n      sortDir = 1;\n    }\n    const sorted = [...rows].sort((a, b) => {\n      let av = a[idx], bv = b[idx];\n      if (type === \"bool\") { av = av ? 1 : 0; bv = bv ? 1 : 0; }\n      if (typeof av === \"string\") {\n        return av.localeCompare(bv) * sortDir;\n      }\n      return (av - bv) * sortDir;\n    });\n    headers.forEach(h => {\n      h.classList.remove(\"sorted\");\n      const arrow = h.querySelector(\".arrow\");\n      arrow.textContent = \"\";\n    });\n    const activeHeader = document.querySelector(`th[data-key=\"${key}\"]`);\n    activeHeader.classList.add(\"sorted\");\n    activeHeader.querySelector(\".arrow\").textContent = sortDir === 1 ? \"▲\" : \"▼\";\n    render(sorted);\n  }\n\n  headers.forEach(h => {\n    h.addEventListener(\"click\", () => {\n      sortBy(h.dataset.key, h.dataset.type);\n    });\n  });\n\n  render(rows);\n</script>\n\n</body>\n</html>\n",
