        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    color-scheme: dark;\n  }\n  body {\n    margin: 0;\n    padding: 40px 24px;\n    background: #0f1115;\n    color: #e6e8eb;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    font-size: 20px;\n    font-weight: 600;\n    margin: 0 0 4px 0;\n    text-align: center;\n  }\n  .subtitle {\n    color: #8b93a1;\n    font-size: 13px;\n    margin-bottom: 28px;\n    text-align: center;\n  }\n  .chart-wrap {\n    background: #171a21;\n    border: 1px solid #262b36;\n    border-radius: 12px;\n    padding: 28px 32px 20px 32px;\n    box-shadow: 0 4px 24px rgba(0,0,0,0.35);\n  }\n  .bar {\n    fill: #e5484d;\n  }\n  .bar:hover {\n    fill: #ff6b70;\n  }\n  .bar-label {\n    fill: #e6e8eb;\n    font-size: 13px;\n    font-weight: 600;\n    text-anchor: middle;\n  }\n  .axis-label {\n    fill: #8b93a1;\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .axis-line {\n    stroke: #3a4150;\n    stroke-width: 1;\n  }\n  .gridline {\n    stroke: #232833;\n    stroke-width: 1;\n  }\n  .ytick {\n    fill: #6b7280;\n    font-size: 11px;\n    text-anchor: end;\n  }\n  .ylabel {\n    fill: #8b93a1;\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .stats {\n    display: flex;\n    gap: 32px;\n    margin-top: 24px;\n    justify-content: center;\n  }\n  .stat {\n    text-align: center;\n  }\n  .stat .value {\n    font-size: 22px;\n    font-weight: 700;\n    color: #e5484d;\n  }\n  .stat .label {\n    font-size: 12px;\n    color: #8b93a1;\n    margin-top: 2px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<div class=\"subtitle\">logs/app.log &middot; 2026-05-11 09:00&ndash;10:00 &middot; ERROR lines per 10-minute bucket</div>\n\n<div class=\"chart-wrap\">\n  <svg id=\"chart\" width=\"640\" height=\"380\" viewBox=\"0 0 640 380\"></svg>\n</div>\n\n<div class=\"stats\">\n  <div class=\"stat\"><div class=\"value\">22</div><div class=\"label\">total ERROR lines</div></div>\n  <div class=\"stat\"><div class=\"value\">09:30</div><div class=\"label\">peak bucket (11 errors)</div></div>\n  <div class=\"stat\"><div class=\"value\">2.1%</div><div class=\"label\">reported hourly error_rate</div></div>\n</div>\n\n<script>\n  const buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 },\n  ];\n\n  const svg = document.getElementById(\"chart\");\n  const W = 640, H = 380;\n  const marginLeft = 50, marginRight = 20, marginTop = 20, marginBottom = 50;\n  const plotW = W - marginLeft - marginRight;\n  const plotH = H - marginTop - marginBottom;\n\n  const maxCount = Math.max(...buckets.map(b => b.count));\n  const yMax = Math.ceil(maxCount / 5) * 5 || 5;\n\n  const ns = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    const e = document.createElementNS(ns, tag);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // Y gridlines + ticks\n  const ySteps = 5;\n  for (let i = 0; i <= ySteps; i++) {\n    const val = (yMax / ySteps) * i;\n    const y = marginTop + plotH - (val / yMax) * plotH;\n    svg.appendChild(el(\"line\", {\n      x1: marginLeft, x2: marginLeft + plotW, y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    const tick = el(\"text\", { x: marginLeft - 10, y: y + 4, class: \"ytick\" });\n    tick.textContent = Math.round(val);\n    svg.appendChild(tick);\n  }\n\n  // Axis line\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: marginLeft, y1: marginTop, y2: marginTop + plotH, class: \"axis-line\"\n  }));\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: marginLeft + plotW, y1: marginTop + plotH, y2: marginTop + plotH, class: \"axis-line\"\n  }));\n\n  // Y axis label\n  const ylabel = el(\"text\", {\n    x: 14, y: marginTop + plotH / 2, class: \"ylabel\",\n    transform: `rotate(-90 14 ${marginTop + plotH / 2})`\n  });\n  ylabel.textContent = \"ERROR count\";\n  svg.appendChild(ylabel);\n\n  const n = buckets.length;\n  const slotW = plotW / n;\n  const barW = slotW * 0.55;\n\n  buckets.forEach((b, i) => {\n    const slotX = marginLeft + i * slotW;\n    const barH = (b.count / yMax) * plotH;\n    const barX = slotX + (slotW - barW) / 2;\n    const barY = marginTop + plotH - barH;\n\n    svg.appendChild(el(\"rect\", {\n      x: barX, y: barY, width: barW, height: Math.max(barH, 0),\n      class: \"bar\", rx: 3\n    }));\n\n    if (b.count > 0) {\n      const countLabel = el(\"text\", {\n        x: barX + barW / 2, y: barY - 8, class: \"bar-label\"\n      });\n      countLabel.textContent = b.count;\n      svg.appendChild(countLabel);\n    }\n\n    const xLabel = el(\"text\", {\n      x: slotX + slotW / 2, y: marginTop + plotH + 22, class: \"axis-label\"\n    });\n    xLabel.textContent = b.label;\n    svg.appendChild(xLabel);\n  });\n</script>\n\n</body>\n</html>\n",
