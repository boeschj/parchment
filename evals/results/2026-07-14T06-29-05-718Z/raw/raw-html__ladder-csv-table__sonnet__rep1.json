onst lines = text.trim().split(\"\\n\");\n  const header = lines.shift().split(\",\");\n  return lines.map(line => {\n    const cells = line.split(\",\");\n    const row = {};\n    header.forEach((h, i) => {\n      let v = cells[i];\n      if (numericColumns.has(h)) v = Number(v);\n      else if (h === \"passed\") v = v === \"true\";\n      row[h] = v;\n    });\n    return row;\n  });\n}\n\nconst data = parseCSV(csv);\nlet sortState = { column: \"run_id\", asc: true };\n\nfunction render() {\n  const { column, asc } = sortState;\n  const sorted = [...data].sort((a, b) => {\n    let av = a[column], bv = b[column];\n    if (typeof av === \"boolean\") { av = av ? 1 : 0; bv = bv ? 1 : 0; }\n    if (av < bv) return asc ? -1 : 1;\n    if (av > bv) return asc ? 1 : -1;\n    return 0;\n  });\n\n  const headerRow = document.getElementById(\"header-row\");\n  headerRow.innerHTML = \"\";\n  columns.forEach(col => {\n    const th = document.createElement(\"th\");\n    th.className = numericColumns.has(col) ? \"num\" : \"\";\n    if (col === column) th.classList.add(\"sorted\");\n    const arrow = col === column ? (asc ? \"▲\" : \"▼\") : \"▲\";\n    th.innerHTML = `${col}<span class=\"arrow\">${arrow}</span>`;\n    th.addEventListener(\"click\", () => {\n      if (sortState.column === col) sortState.asc = !sortState.asc;\n      else sortState = { column: col, asc: true };\n      render();\n    });\n    headerRow.appendChild(th);\n  });\n\n  const tbody = document.getElementById(\"table-body\");\n  tbody.innerHTML = \"\";\n  sorted.forEach(row => {\n    const tr = document.createElement(\"tr\");\n    columns.forEach(col => {\n      const td = document.createElement(\"td\");\n      const val = row[col];\n      if (numericColumns.has(col)) {\n        td.className = \"num\";\n        td.textContent = val;\n      } else if (col === \"passed\") {\n        td.innerHTML = `<span class=\"pass-${val}\">${val}</span>`;\n      } else if (col === \"run_id\") {\n        td.innerHTML = `<code>