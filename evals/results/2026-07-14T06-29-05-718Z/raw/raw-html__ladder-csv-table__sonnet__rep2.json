\");\n        const colName = columns[i];\n        if (colName === \"tokens_in\" || colName === \"tokens_out\" || colName === \"latency_ms\") {\n          td.className = \"num\";\n          td.textContent = val;\n        } else if (colName === \"passed\") {\n          td.textContent = val ? \"true\" : \"false\";\n          td.className = val ? \"pass-true\" : \"pass-false\";\n        } else {\n          td.textContent = val;\n        }\n        tr.appendChild(td);\n      });\n      tbody.appendChild(tr);\n    }\n    document.getElementById(\"row-count\").textContent = `Showing ${rows.length} rows`;\n  }\n\n  function sortBy(colIndex, type) {\n    if (currentSort.col === colIndex) {\n      currentSort.dir *= -1;\n    } else {\n      currentSort.col = colIndex;\n      currentSort.dir = 1;\n    }\n    rows.sort((a, b) => {\n      let av = a[colIndex], bv = b[colIndex];\n      if (type === \"num\") {\n        return (av - bv) * currentSort.dir;\n      } else if (type === \"bool\") {\n        return ((av === bv) ? 0 : (av ? 1 : -1)) * currentSort.dir;\n      } else {\n        return String(av).localeCompare(String(bv)) * currentSort.dir;\n      }\n    });\n    document.querySelectorAll(\"thead th\").forEach((th, i) => {\n      th.classList.remove(\"sorted-asc\", \"sorted-desc\");\n      const arrow = th.querySelector(\".arrow\");\n      if (i === colIndex) {\n        th.classList.add(currentSort.dir === 1 ? \"sorted-asc\" : \"sorted-desc\");\n        arrow.textContent = currentSort.dir === 1 ? \"▲\" : \"▼\";\n      } else {\n        arrow.textContent = \"▲\";\n      }\n    });\n    render();\n  }\n\n  document.querySelectorAll(\"thead th\").forEach((th, i) => {\n    th.addEventListener(\"click\", () => sortBy(i, th.dataset.type));\n  });\n\n  render();\n</script>\n\n</body>\n</html>\n",
