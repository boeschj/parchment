        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Chart the error rate over time from a log file on disk</title>\n<style>\n  :root {\n    --ink: #1b1f27;\n    --muted: #6b7280;\n    --grid: #e5e7eb;\n    --bar: #c0392b;\n    --bar-top: #e05a4a;\n    --bg: #fafaf8;\n    --panel: #ffffff;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 20px;\n    background: var(--bg);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    color: var(--ink);\n    display: flex;\n    justify-content: center;\n  }\n  .wrap {\n    width: 100%;\n    max-width: 880px;\n  }\n  h1 {\n    font-size: 20px;\n    font-weight: 650;\n    margin: 0 0 4px 0;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 13.5px;\n    margin: 0 0 28px 0;\n  }\n  .panel {\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 10px;\n    padding: 28px 32px 20px 32px;\n    box-shadow: 0 1px 2px rgba(0,0,0,0.03);\n  }\n  .stats {\n    display: flex;\n    gap: 28px;\n    margin-bottom: 22px;\n    flex-wrap: wrap;\n  }\n  .stat {\n    display: flex;\n    flex-direction: column;\n  }\n  .stat .value {\n    font-size: 22px;\n    font-weight: 650;\n    line-height: 1.2;\n  }\n  .stat .label {\n    font-size: 11.5px;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n  .stat.error .value { color: var(--bar); }\n  svg {\n    display: block;\n    width: 100%;\n    height: auto;\n    overflow: visible;\n  }\n  .bar-count {\n    font-size: 13px;\n    font-weight: 650;\n    fill: var(--ink);\n    text-anchor: middle;\n  }\n  .x-label {\n    font-size: 12px;\n    fill: var(--muted);\n    text-anchor: middle;\n  }\n  .y-label {\n    font-size: 11px;\n    fill: var(--muted);\n    text-anchor: end;\n  }\n  .gridline {\n    stroke: var(--grid);\n    stroke-width: 1;\n  }\n  .axis-line {\n    stroke: #d1d5db;\n    stroke-width: 1;\n  }\n  .bar {\n    fill: var(--bar);\n    rx: 3;\n  }\n  .bar:hover {\n    fill: var(--bar-top);\n  }\n  .axis-title {\n    font-size: 12px;\n    fill: var(--muted);\n    text-anchor: middle;\n  }\n  footer {\n    margin-top: 16px;\n    font-size: 12px;\n    color: var(--muted);\n  }\n  code {\n    background: #f1f1ee;\n    padding: 1px 5px;\n    border-radius: 4px;\n    font-size: 11.5px;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <h1>Chart the error rate over time from a log file on disk</h1>\n  <p class=\"subtitle\">ERROR lines per 10-minute bucket &mdash; <code>logs/app.log</code>, 2026-05-11 09:00&ndash;10:00 UTC</p>\n\n  <div class=\"panel\">\n    <div class=\"stats\" id=\"stats\"></div>\n    <svg id=\"chart\" viewBox=\"0 0 800 360\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n  </div>\n\n  <footer>100 log lines parsed &middot; bucketed by 10-minute window starting at each label &middot; counts reflect lines matching <code>ERROR</code></footer>\n</div>\n\n<script>\n// Bucket counts derived from logs/app.log (22 ERROR lines total, one hour window)\nconst buckets = [\n  { label: \"09:00\", count: 0 },\n  { label: \"09:10\", count: 1 },\n  { label: \"09:20\", count: 5 },\n  { label: \"09:30\", count: 11 },\n  { label: \"09:40\", count: 4 },\n  { label: \"09:50\", count: 1 },\n];\n\nconst totalErrors = buckets.reduce((s, b) => s + b.count, 0);\nconst totalRequests = 1042;\nconst errorRate = (totalErrors / totalRequests * 100).toFixed(1);\nconst peak = buckets.reduce((a, b) => (b.count > a.count ? b : a), buckets[0]);\n\ndocument.getElementById(\"stats\").innerHTML = `\n  <div class=\"stat error\">\n    <span class=\"value\">${totalErrors}</span>\n    <span class=\"label\">Total ERROR lines</span>\n  </div>\n  <div class=\"stat\">\n    <span class=\"value\">${errorRate}%</span>\n    <span class=\"label\">Error rate (of ${totalRequests} requests)</span>\n  </div>\n  <div class=\"stat\">\n    <span class=\"value\">${peak.label}&ndash;${addTenMin(peak.label)}</span>\n    <span class=\"label\">Peak bucket (${peak.count} errors)</span>\n  </div>\n`;\n\nfunction addTenMin(hhmm) {\n  const [h, m] = hhmm.split(\":\").map(Number);\n  const total = h * 60 + m + 10;\n  const nh = Math.floor(total / 60) % 24;\n  const nm = total % 60;\n  return String(nh).padStart(2, \"0\") + \":\" + String(nm).padStart(2, \"0\");\n}\n\n// --- SVG chart rendering ---\nconst svgNS = \"http://www.w3.org/2000/svg\";\nconst svg = document.getElementById(\"chart\");\n\nconst W = 800, H = 360;\nconst marginTop = 20, marginRight = 20, marginBottom = 56, marginLeft = 46;\nconst plotW = W - marginLeft - marginRight;\nconst plotH = H - marginTop - marginBottom;\n\nconst maxCount = Math.max(...buckets.map(b => b.count));\nconst yMax = Math.ceil((maxCount + 1) / 2) * 2; // round up to nice even number\nconst yStep = yMax <= 4 ? 1 : 2;\n\nfunction el(tag, attrs) {\n  const node = document.createElementNS(svgNS, tag);\n  for (const k in attrs) node.setAttribute(k, attrs[k]);\n  return node;\n}\n\n// Y gridlines + labels\nfor (let v = 0; v <= yMax; v += yStep) {\n  const y = marginTop + plotH - (v / yMax) * plotH;\n  svg.appendChild(el(\"line\", {\n    class: \"gridline\",\n    x1: marginLeft, x2: marginLeft + plotW, y1: y, y2: y\n  }));\n  const label = el(\"text\", { class: \"y-label\", x: marginLeft - 10, y: y + 4 });\n  label.textContent = v;\n  svg.appendChild(label);\n}\n\n// Axis line\nsvg.appendChild(el(\"line\", {\n  class: \"axis-line\",\n  x1: marginLeft, x2: marginLeft, y1: marginTop, y2: marginTop + plotH\n}));\nsvg.appendChild(el(\"line\", {\n  class: \"axis-line\",\n  x1: marginLeft, x2: marginLeft + plotW, y1: marginTop + plotH, y2: marginTop + plotH\n}));\n\n// Bars\nconst n = buckets.length;\nconst slot = plotW / n;\nconst barW = slot * 0.5;\n\nbuckets.forEach((b, i) => {\n  const slotX = marginLeft + i * slot;\n  const barH = (b.count / yMax) * plotH;\n  const x = slotX + (slot - barW) / 2;\n  const y = marginTop + plotH - barH;\n\n  const rect = el(\"rect\", {\n    class: \"bar\",\n    x: x,\n    y: b.count === 0 ? y - 2 : y,\n    width: barW,\n    height: b.count === 0 ? 2 : barH,\n    rx: 3\n  });\n  svg.appendChild(rect);\n\n  const countLabel = el(\"text\", {\n    class: \"bar-count\",\n    x: slotX + slot / 2,\n    y: (b.count === 0 ? y - 2 : y) - 8\n  });\n  countLabel.textContent = b.count;\n  svg.appendChild(countLabel);\n\n  const xLabel = el(\"text\", {\n    class: \"x-label\",\n    x: slotX + slot / 2,\n    y: marginTop + plotH + 22\n  });\n  xLabel.textContent = b.label;\n  svg.appendChild(xLabel);\n});\n\n// Axis titles\nconst xTitle = el(\"text\", {\n  class: \"axis-title\",\n  x: marginLeft + plotW / 2,\n  y: H - 6\n});\nxTitle.textContent = \"Bucket start time (10-minute windows, 2026-05-11)\";\nsvg.appendChild(xTitle);\n\nconst yTitle = el(\"text\", {\n  class: \"axis-title\",\n  transform: `translate(14, ${marginTop + plotH / 2}) rotate(-90)`\n});\nyTitle.textContent = \"ERROR lines\";\nsvg.appendChild(yTitle);\n</script>\n</body>\n</html>\n",
