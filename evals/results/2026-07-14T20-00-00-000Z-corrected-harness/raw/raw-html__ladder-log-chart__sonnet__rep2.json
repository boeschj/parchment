        "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Error rate over time</title>\n<style>\n  :root {\n    --bg: #0f1117;\n    --panel: #171a23;\n    --grid: #2a2f3d;\n    --text: #e6e8ef;\n    --muted: #9aa1b2;\n    --bar: #ef5a63;\n    --bar-top: #ff7b83;\n    --accent: #4fd1c5;\n  }\n  * { box-sizing: border-box; }\n  body {\n    margin: 0;\n    padding: 40px 20px;\n    background: var(--bg);\n    color: var(--text);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif;\n    display: flex;\n    justify-content: center;\n  }\n  .wrap {\n    width: 100%;\n    max-width: 860px;\n  }\n  h1 {\n    font-size: 1.3rem;\n    font-weight: 600;\n    margin: 0 0 4px 0;\n  }\n  .subtitle {\n    color: var(--muted);\n    font-size: 0.9rem;\n    margin: 0 0 28px 0;\n  }\n  .panel {\n    background: var(--panel);\n    border: 1px solid var(--grid);\n    border-radius: 12px;\n    padding: 28px 28px 16px 28px;\n  }\n  .stats {\n    display: flex;\n    gap: 32px;\n    margin-bottom: 20px;\n    flex-wrap: wrap;\n  }\n  .stat {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n  .stat .value {\n    font-size: 1.6rem;\n    font-weight: 700;\n  }\n  .stat .value.accent { color: var(--bar-top); }\n  .stat .label {\n    font-size: 0.75rem;\n    color: var(--muted);\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n  svg { display: block; width: 100%; height: auto; }\n  .gridline { stroke: var(--grid); stroke-width: 1; }\n  .axis-label { fill: var(--muted); font-size: 12px; }\n  .bar { fill: var(--bar); }\n  .bar:hover { fill: var(--bar-top); }\n  .bar-label { fill: var(--text); font-size: 12px; font-weight: 600; text-anchor: middle; }\n  .footer-note {\n    color: var(--muted);\n    font-size: 0.78rem;\n    margin-top: 18px;\n    padding-top: 14px;\n    border-top: 1px solid var(--grid);\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <h1>Chart the error rate over time from a log file on disk</h1>\n  <p class=\"subtitle\">logs/app.log &mdash; 100 lines spanning 2026-05-11 09:00&ndash;10:00, bucketed into ten-minute intervals</p>\n\n  <div class=\"panel\">\n    <div class=\"stats\">\n      <div class=\"stat\">\n        <span class=\"value accent\" id=\"stat-total\"></span>\n        <span class=\"label\">Total errors</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"value\" id=\"stat-peak\"></span>\n        <span class=\"label\">Peak bucket</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"value\" id=\"stat-rate\"></span>\n        <span class=\"label\">Overall error rate</span>\n      </div>\n    </div>\n\n    <svg id=\"chart\" viewBox=\"0 0 760 340\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n\n    <p class=\"footer-note\">Each bucket covers [HH:MM, HH:MM+10) of 2026-05-11. Counts reflect lines logged at level <code>ERROR</code> only.</p>\n  </div>\n</div>\n\n<script>\n  // Bucket start times and ERROR counts, derived from logs/app.log\n  var buckets = [\n    { label: \"09:00\", count: 0 },\n    { label: \"09:10\", count: 1 },\n    { label: \"09:20\", count: 5 },\n    { label: \"09:30\", count: 11 },\n    { label: \"09:40\", count: 4 },\n    { label: \"09:50\", count: 1 }\n  ];\n\n  var total = buckets.reduce(function (sum, b) { return sum + b.count; }, 0);\n  var peak = buckets.reduce(function (max, b) { return b.count > max.count ? b : max; }, buckets[0]);\n\n  document.getElementById(\"stat-total\").textContent = total;\n  document.getElementById(\"stat-peak\").textContent = peak.label + \" (\" + peak.count + \")\";\n  document.getElementById(\"stat-rate\").textContent = (total / 1042 * 100).toFixed(1) + \"%\";\n\n  var svgNS = \"http://www.w3.org/2000/svg\";\n  var svg = document.getElementById(\"chart\");\n\n  var W = 760, H = 340;\n  var marginLeft = 46, marginRight = 20, marginTop = 20, marginBottom = 50;\n  var plotW = W - marginLeft - marginRight;\n  var plotH = H - marginTop - marginBottom;\n\n  var maxCount = Math.max.apply(null, buckets.map(function (b) { return b.count; }));\n  var yMax = Math.ceil((maxCount + 1) / 5) * 5;\n  if (yMax < 5) yMax = 5;\n\n  function el(tag, attrs) {\n    var e = document.createElementNS(svgNS, tag);\n    for (var k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // Gridlines + y-axis labels\n  var ySteps = 5;\n  for (var i = 0; i <= ySteps; i++) {\n    var val = Math.round(yMax * i / ySteps);\n    var y = marginTop + plotH - (plotH * i / ySteps);\n    svg.appendChild(el(\"line\", {\n      x1: marginLeft, x2: marginLeft + plotW, y1: y, y2: y,\n      class: \"gridline\"\n    }));\n    var label = el(\"text\", {\n      x: marginLeft - 10, y: y + 4,\n      class: \"axis-label\", \"text-anchor\": \"end\"\n    });\n    label.textContent = val;\n    svg.appendChild(label);\n  }\n\n  // Bars\n  var n = buckets.length;\n  var slot = plotW / n;\n  var barWidth = slot * 0.55;\n\n  buckets.forEach(function (b, i) {\n    var barH = (b.count / yMax) * plotH;\n    var x = marginLeft + slot * i + (slot - barWidth) / 2;\n    var y = marginTop + plotH - barH;\n\n    var rect = el(\"rect\", {\n      x: x, y: y, width: barWidth, height: Math.max(barH, 0),\n      class: \"bar\", rx: 3\n    });\n    var title = el(\"title\", {});\n    title.textContent = b.label + \" – \" + b.count + \" error\" + (b.count === 1 ? \"\" : \"s\");\n    rect.appendChild(title);\n    svg.appendChild(rect);\n\n    if (b.count > 0) {\n      var countLabel = el(\"text\", {\n        x: x + barWidth / 2, y: y - 8,\n        class: \"bar-label\"\n      });\n      countLabel.textContent = b.count;\n      svg.appendChild(countLabel);\n    }\n\n    var xLabel = el(\"text\", {\n      x: x + barWidth / 2, y: marginTop + plotH + 22,\n      class: \"axis-label\", \"text-anchor\": \"middle\"\n    });\n    xLabel.textContent = b.label;\n    svg.appendChild(xLabel);\n  });\n\n  // Axis lines\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: marginLeft, y1: marginTop, y2: marginTop + plotH,\n    class: \"gridline\"\n  }));\n  svg.appendChild(el(\"line\", {\n    x1: marginLeft, x2: marginLeft + plotW, y1: marginTop + plotH, y2: marginTop + plotH,\n    class: \"gridline\"\n  }));\n</script>\n</body>\n</html>\n",
