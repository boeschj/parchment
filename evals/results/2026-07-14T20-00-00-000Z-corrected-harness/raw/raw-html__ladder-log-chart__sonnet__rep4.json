e: 11.5px;\n    text-anchor: middle;\n  }\n  .axis-title {\n    fill: var(--muted);\n    font-size: 12px;\n    text-anchor: middle;\n  }\n  .peak-note {\n    fill: var(--accent);\n    font-size: 11px;\n    text-anchor: middle;\n    font-weight: 600;\n  }\n  footer {\n    margin-top: 18px;\n    color: var(--muted);\n    font-size: 11.5px;\n    text-align: center;\n  }\n  code {\n    background: #10131a;\n    border: 1px solid var(--grid);\n    padding: 1px 5px;\n    border-radius: 4px;\n    color: #cfd6e4;\n  }\n</style>\n</head>\n<body>\n\n<h1>Chart the error rate over time from a log file on disk</h1>\n<div class=\"subtitle\">ERROR lines per 10-minute bucket &mdash; <code>logs/app.log</code>, 2026&#8209;05&#8209;11 09:00&ndash;10:00 UTC</div>\n\n<div class=\"card\">\n  <div class=\"stats\" id=\"stats\"></div>\n  <svg id=\"chart\" viewBox=\"0 0 720 360\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n</div>\n\n<footer>100 log lines parsed in-browser &middot; bucketed by ERROR timestamp into six 10-minute windows starting 09:00</footer>\n\n<script>\n// Raw content of logs/app.log, embedded so the page is self-contained (no file access at runtime).\nconst LOG_TEXT = `2026-05-11T09:00:04.182Z INFO  [server] server_listening port=8080 timeout_ms=15000\n2026-05-11T09:00:04.196Z INFO  [store] inventory_snapshot_loaded items=1284 duration_ms=312\n2026-05-11T09:00:05.044Z INFO  [pricing] upstream_connected host=pricing.internal pool=8\n2026-05-11T09:01:12.663Z INFO  [http] request_completed method=GET path=/healthz status=200 duration_ms=3\n2026-05-11T09:01:47.028Z INFO  [http] request_completed method=GET path=/catalog status=200 duration_ms=142 cache=miss\n2026-05-11T09:02:19.517Z INFO  [http] request_completed method=GET path=/catalog status=200 duration_ms=11 cache=hit\n2026-05-11T09:03:02.884Z INFO  [http] request_completed method=POST path=/catalog status=201 duration_ms=204 sku=KTL-4417\n2026-05-11T09:03:41.330Z INFO  [cache] catalog_cache_invalidated reason=item_crea