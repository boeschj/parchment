,4560,false\nr044,mermaid_render,claude-sonnet-4-6,path_ref,864,612,2043,true\nr045,mermaid_render,claude-sonnet-4-6,inline_paste,1729,628,3115,true\nr046,mermaid_render,claude-sonnet-4-6,no_render,801,1298,3402,false\nr047,mermaid_render,claude-haiku-4-5,path_ref,858,571,1236,true\nr048,mermaid_render,claude-haiku-4-5,inline_paste,1721,933,2488,false\nr049,mermaid_render,claude-haiku-4-5,no_render,796,1224,1893,false\nr050,mermaid_render,claude-opus-4-8,path_ref,883,647,2954,true`;\n\nfunction parseCSV(text) {\n  const lines = text.trim().split('\\n');\n  const headers = lines[0].split(',');\n  return lines.slice(1).map(line => {\n    const cells = line.split(',');\n    const row = {};\n    headers.forEach((h, i) => row[h] = cells[i]);\n    return row;\n  });\n}\n\nconst rows = parseCSV(csvData);\nconst tbody = document.querySelector('#results-table tbody');\nconst headerCells = document.querySelectorAll('#results-table thead th');\n\nfunction renderRows(data) {\n  tbody.innerHTML = '';\n  data.forEach(row => {\n    const tr = document.createElement('tr');\n    tr.innerHTML = `\n      <td>${row.run_id}</td>\n      <td>${row.scenario}</td>\n      <td>${row.model}</td>\n      <td>${row.arm}</td>\n      <td class=\"num\">${row.tokens_in}</td>\n      <td class=\"num\">${row.tokens_out}</td>\n      <td class=\"num\">${row.latency_ms}</td>\n      <td class=\"pass-${row.passed}\">${row.passed}</td>\n    `;\n    tbody.appendChild(tr);\n  });\n  document.getElementById('row-count').textContent = `${data.length} rows`;\n}\n\nlet currentSort = { key: null, dir: 1 };\n\nfunction sortBy(key, type) {\n  if (currentSort.key === key) {\n    currentSort.dir *= -1;\n  } else {\n    currentSort = { key, dir: 1 };\n  }\n  const sorted = [...rows].sort((a, b) => {\n    let va = a[key], vb = b[key];\n    if (type === 'number') {\n      va = Number(va); vb = Number(vb);\n    } else if (type === 'bool') {\n      va = va === 'true' ? 1 : 0;\n      vb = vb === 'true' ? 1 : 0;\n    } else {\n      va = va.toLowerCase(); vb = vb.toLowerCase();\n    }\n    if (va < vb) return -1 * currentSort.dir;\n    if (va > vb) return 1 * currentSort.dir;\n    return 0;\n  });\n  renderRows(sorted);\n  headerCells.forEach(th => {\n    th.classList.remove('sorted');\n    th.querySelector('.arrow').textContent = '';\n  });\n  const activeTh = document.querySelector(`th[data-key=\"${key}\"]`);\n  activeTh.classList.add('sorted');\n  activeTh.querySelector('.arrow').textContent = currentSort.dir === 1 ? '▲' : '▼';\n}\n\nheaderCells.forEach(th => {\n  th.addEventListener('click', () => sortBy(th.dataset.key, th.dataset.type));\n});\n\nrenderRows(rows);\n</script>\n\n</body>\n</html>\n",
