{
  "name": "clawd-canvas",
  "version": "0.2.0",
  "description": "Generative-UI canvas for Claude Code. Claude calls MCP tools, your browser tab renders json-render specs (shadcn + extensions: PlanFile, DiffViewer, MermaidEditor, Chart, DataTable), edits flow back via UserPromptSubmit.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "clawd-canvas": "./src/cli/main.ts"
  },
  "scripts": {
    "dev:daemon": "bun --watch run src/daemon/server.ts",
    "dev:browser": "vite",
    "build": "bun run build:browser && bun run typecheck",
    "build:browser": "vite build",
    "typecheck": "tsc --noEmit",
    "cli": "bun run src/cli/main.ts"
  },
  "dependencies": {
    "@json-render/core": "latest",
    "@json-render/react": "latest",
    "@json-render/shadcn": "latest",
    "@json-render/mcp": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "latest",
    "@tiptap/core": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "dompurify": "latest",
    "mermaid": "^11.0.0",
    "monaco-editor": "latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "tiptap-markdown": "latest",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/dompurify": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0"
  }
}
