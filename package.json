{
  "name": "parchment",
  "version": "0.1.0",
  "description": "Parchment is the visual layer for agentic coding tools: a generative-UI canvas rendered in the browser. Claude calls canvas_* MCP tools, your browser tab renders json-render specs (shadcn + extensions: PlanFile, DiffViewer, MermaidEditor, Chart, DataTable), and edits flow back via UserPromptSubmit.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "parchment": "./src/cli/main.ts"
  },
  "scripts": {
    "dev:daemon": "bun --watch run src/daemon/server.ts",
    "dev:browser": "vite",
    "build": "pnpm build:browser && pnpm typecheck",
    "build:browser": "vite build",
    "typecheck": "tsc --noEmit",
    "cli": "bun run src/cli/main.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@boeschj/claude-jsonl": "file:vendor/boeschj-claude-jsonl-0.1.1.tgz",
    "@json-render/core": "0.19.0",
    "@json-render/mcp": "0.19.0",
    "@json-render/react": "0.19.0",
    "@json-render/shadcn": "0.19.0",
    "@mcp-ui/client": "^7.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tiptap/core": "^3.0.0",
    "@tiptap/react": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "dompurify": "^3.4.12",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.0.0",
    "monaco-editor": "0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "streamdown": "^2.5.0",
    "three": "^0.183.0",
    "tiptap-markdown": "0.9.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0"
  }
}
